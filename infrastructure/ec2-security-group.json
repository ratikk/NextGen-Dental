{
  "GroupName": "LilacDental-WebSG",
  "Description": "Security group for Lilac Dental web servers",
  "SecurityGroupIngress": [
    {
      "IpProtocol": "tcp",
      "FromPort": 80,
      "ToPort": 80,
      "CidrIp": "0.0.0.0/0",
      "Description": "Allow HTTP"
    },
    {
      "IpProtocol": "tcp", 
      "FromPort": 443,
      "ToPort": 443,
      "CidrIp": "0.0.0.0/0",
      "Description": "Allow HTTPS"
    },
    {
      "IpProtocol": "tcp",
      "FromPort": 22,
      "ToPort": 22,
      "CidrIp": "YOUR_IP/32",
      "Description": "Allow SSH from your IP"
    }
  ]
}