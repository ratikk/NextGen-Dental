---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { clinicInfo } from '../utils/clinicInfo';
---

<Layout
  title="Page Not Found | NextGen Dental Austin"
  description="The page you are looking for does not exist. Return to NextGen Dental home page."
>
  <div class="min-h-[70vh] flex items-center justify-center bg-gray-50 px-4">
    <div class="text-center max-w-xl mx-auto">
      <h1 class="text-9xl font-bold text-primary-100 font-heading leading-none mb-4">404</h1>
      
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-6">
        Oops! Page Not Found
      </h2>
      
      <p class="text-lg text-gray-600 mb-8">
        We can't seem to find the page you're looking for. It might have been moved or deleted. 
        But don't worry, we can still help you find a great dentist!
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button
          href="/"
          text="Back to Home"
          variant="primary"
          size="lg"
        />
        <Button
          href="/contact"
          text="Contact Us"
          variant="outline"
          size="lg"
        />
      </div>

      <div class="mt-12 pt-8 border-t border-gray-200">
        <p class="text-sm text-gray-500 mb-2">Need immediate assistance?</p>
        <a href={`tel:${clinicInfo.phone}`} class="text-xl font-bold text-primary-600 hover:underline">
          {clinicInfo.displayPhone || clinicInfo.phone}
        </a>
      </div>
    </div>
  </div>
</Layout>
