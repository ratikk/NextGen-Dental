---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FeatureCard from '../components/FeatureCard.astro';
import Testimonials from '../components/Testimonials.astro';
import BookingPopup from '../components/BookingPopup.astro';

// Constants
const phoneNumber = "+17372913927";
const phoneDisplay = "(737) 291-3927";
const modentoBookingLink = "https://book.modento.io/lilac-dental/patient-details";

const address = {
  line1: "12314 N Interstate Hwy 35 Ste 110",
  cityStateZip: "Austin, TX 78753"
};
const marqueeTagline = "Relax. You've Found Central Texas' #1 Dentist for Restoring Your Natural Smile.";

const fullAddress = `${address.line1}, ${address.cityStateZip}`;
let googleMapsDirectionsUrl = `https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(fullAddress)}`;

const heroImages = [
  "/images/hero/dental-1.jpg",
  "/images/hero/dental-2.jpg",
  "/images/hero/dental-3.jpg",
  "/images/hero/dental-4.jpg",
  "/images/hero/dental-5.jpg",
  "/images/hero/dental-6.jpg"
];

const heroTexts = [
  {
    title: "Aesthetic Smiles",
    subtitle: "Renewing Dental Implants, Veneers, and Teeth Whitening Treatments",
    linkText: "See all Dental Treatments",
    linkUrl: "/services"
  },
  {
    title: "Your Family Dentist",
    subtitle: "Comprehensive care for all ages in a comfortable setting.",
    linkText: "Meet Our Team",
    linkUrl: "/about"
  },
  {
    title: "Advanced Dental Tech",
    subtitle: "Utilizing the latest technology for precise and comfortable care.",
    linkText: "Explore Technology",
    linkUrl: "/technology"
  }
];
---

<Layout title="Lilac Dental | Austin Dental Care & Aesthetic Smiles">
  {/* 
    IMPORTANT: Ensure Swiper.js CSS and JS are loaded in your Layout.astro or a shared head.
    Example for Layout.astro:
    <head>
        ...
        <link rel="stylesheet" href="https://unpkg.com/swiper/swiper-bundle.min.css" />
        <script src="https://unpkg.com/swiper/swiper-bundle.min.js" defer></script> 
        ...
    </head>
  */}

  <div class="hidden lg:block">
    <BookingPopup />
  </div>

  {/* --- Mobile View --- */}
  <div class="lg:hidden">
    <div id="mobile-hero-content-wrapper">
      <div class="h-[50vh] sm:h-[60vh] relative">
        <div class="swiper hero-swiper-mobile h-full">
          <div class="swiper-wrapper">
            {heroImages.map((image, index) => (
              <div class="swiper-slide">
                <img src={image} alt={`Lilac Dental Austin - Mobile View ${index + 1}`}
                  class="w-full h-full object-cover object-center" loading={index === 0 ? "eager" : "lazy"} decoding="async"
                  fetchpriority={index === 0 ? "high" : "low"} />
                <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-black/10 to-transparent"></div>
              </div>
            ))}
          </div>
          <div class="swiper-pagination mobile-swiper-pagination !bottom-4"></div>
        </div>
        <div class="absolute inset-x-0 bottom-0 p-6 text-center">
          <h1 class="text-3xl font-bold text-white mb-2 drop-shadow-lg">{heroTexts[0].title}</h1>
          <p class="text-white/95 text-md mb-4 drop-shadow-lg">{heroTexts[0].subtitle.split(',')[0]}</p>
        </div>
      </div>

      <div class="bg-white py-4 px-4 shadow-md">
        <div class="flex gap-3 mb-3">
          <a href={`tel:${phoneNumber}`}
            class="flex-1 bg-primary-600 text-white px-4 py-3 rounded-lg text-center text-sm font-semibold hover:bg-primary-700 transition-colors">
            Call Us
          </a>
          <a href={modentoBookingLink} target="_blank" rel="noopener noreferrer"
            class="flex-1 bg-secondary-500 text-white px-4 py-3 rounded-lg text-sm font-semibold hover:bg-secondary-600 transition-colors text-center">
            Book Now
          </a>
        </div>
      </div>
    </div>

    {/* --- Mobile "Request an Appointment" Inline Form Section (Initially Hidden) --- */}
    {/* This section is intended to be triggered by a dedicated "Request an Appointment" link/button
        (e.g., in your mobile navigation menu - the "4 line bar").
        The example trigger button that was here has been REMOVED.
        You will need to add an element (e.g., in your nav) with id="trigger-mobile-request-form"
        or adapt the JavaScript to target your chosen trigger element.
    */}
    <div id="mobile-request-appointment-form-section" class="hidden bg-white p-4 md:p-6 my-4 mx-2 rounded-lg shadow-xl border border-neutral-200">
      <div class="flex justify-between items-center mb-4">
        <h2 class="text-xl font-bold text-purple-700">Request an Appointment</h2>
        <button id="close-mobile-request-form-btn" class="text-neutral-500 hover:text-neutral-700 p-1">
             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
        </button>
      </div>
      <form id="mobile-request-form" class="space-y-3.5">
        <div>
          <label for="mobile_req_full_name" class="block text-xs font-medium text-neutral-600 mb-1">Full Name</label>
          <input type="text" id="mobile_req_full_name" name="fullName" placeholder="John Doe" required
            class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm" />
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label for="mobile_req_email" class="block text-xs font-medium text-neutral-600 mb-1">Email</label>
            <input type="email" id="mobile_req_email" name="email" placeholder="john@example.com" required
              class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm" />
          </div>
          <div>
            <label for="mobile_req_phone" class="block text-xs font-medium text-neutral-600 mb-1">Phone Number</label>
            <input type="tel" id="mobile_req_phone" name="phone" placeholder="(555) 123-4567" required
              class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm" />
          </div>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div>
            <label for="mobile_req_pref_date" class="block text-xs font-medium text-neutral-600 mb-1">Preferred Date</label>
            <input type="date" id="mobile_req_pref_date" name="preferredDate"
              class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm appearance-none" />
          </div>
          <div>
            <label for="mobile_req_pref_time" class="block text-xs font-medium text-neutral-600 mb-1">Preferred Time</label>
            <select id="mobile_req_pref_time" name="preferredTime"
              class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm">
              <option value="" disabled selected>Select a time</option>
              <option value="morning">Morning</option>
              <option value="afternoon">Afternoon</option>
            </select>
          </div>
        </div>
        <div>
          <label for="mobile_req_reason" class="block text-xs font-medium text-neutral-600 mb-1">Reason for Visit</label>
          <select id="mobile_req_reason" name="reasonForVisit"
            class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm">
            <option value="" disabled selected>Select a reason</option>
            <option value="checkup">Routine Checkup & Cleaning</option>
            <option value="consultation">Consultation</option>
            <option value="whitening">Teeth Whitening</option>
            <option value="pain">Pain or Discomfort</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="flex items-start space-x-2 pt-1">
          <input id="mobile_req_sms_consent" name="smsConsent" type="checkbox" required
            class="h-4 w-4 text-purple-600 border-neutral-300 rounded focus:ring-purple-500 mt-0.5" />
          <label for="mobile_req_sms_consent" class="text-xs text-neutral-600">
            By checking this box you will be agreeing to receive text messages from Lilac Dental.
          </label>
        </div>
        <div class="mt-3 p-3 bg-neutral-100 border border-neutral-200 rounded-md text-center text-sm text-neutral-500">
          CAPTCHA verification would appear here.
        </div>
        <button type="submit"
          class="w-full bg-purple-600 text-white font-semibold py-2.5 px-6 rounded-md hover:bg-purple-700 transition-colors text-sm mt-2">
          Send Request
        </button>
      </form>
    </div>


    <div id="mobile-lower-content-wrapper">
        <section class="bg-gradient-to-r from-purple-700 via-purple-500 to-purple-700 py-3 overflow-hidden relative">
        <div class="marquee-container whitespace-nowrap">
            <div class="marquee-content flex space-x-8">
            <span class="marquee-text text-white text-sm font-semibold drop-shadow-sm">
                {marqueeTagline}
            </span>
            <span class="marquee-text text-white text-sm font-semibold drop-shadow-sm">
                {marqueeTagline}
            </span>
            </div>
        </div>
        </section>
        <div class="bg-white p-4 shadow-md">
        <a href={googleMapsDirectionsUrl} target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-between text-neutral-700 hover:text-primary-600 transition-colors">
            <div class="flex items-center">
            <div class="bg-purple-100 p-2 rounded-full mr-3">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor"
                class="w-5 h-5 text-purple-600">
                <path fill-rule="evenodd"
                    d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 103 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 002.273 1.765 11.842 11.842 0 00.976.544l.062.029.018.008.006.003zM10 11.25a2.25 2.25 0 100-4.5 2.25 2.25 0 000 4.5z"
                    clip-rule="evenodd" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-medium">Our Location:</p>
                <p class="text-sm">{address.line1}</p>
                <p class="text-sm">{address.cityStateZip}</p>
            </div>
            </div>
            <div class="text-purple-600">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                <path fill-rule="evenodd"
                d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
                clip-rule="evenodd" />
            </svg>
            </div>
        </a>
        </div>
    </div>
  </div>


  {/* --- Desktop View Hero --- */}
  <div class="hidden lg:block">
    <section class="relative h-[clamp(580px,80vh,700px)]">
      <div class="absolute inset-y-0 left-0 z-0 border-2 border-white/40 rounded-md overflow-hidden"
        style="width: calc(100% - 420px);">
        <div class="swiper hero-swiper-desktop h-full">
          <div class="swiper-wrapper">
            {heroImages.map((image, index) => (
              <div class="swiper-slide bg-black">
                <img src={image} alt={`Lilac Dental Austin - ${heroTexts[index % heroTexts.length]?.title || `Hero Image ${index + 1}`}`}
                  class="w-full h-full object-contain object-center" loading={index === 0 ? "eager" : "lazy"}
                  decoding="async" fetchpriority={index === 0 ? "high" : "low"} />
                <div class="absolute inset-0 bg-black/25"></div>
              </div>
            ))}
          </div>
        </div>
      </div>
      <div class="absolute z-10 left-0 bottom-0 px-4" style="width: calc(100% - 420px);">
        <div class="container mx-auto">
          <div class="flex-grow">
            <div class="w-full h-auto p-5 text-center text-white bg-black/30 backdrop-blur-sm rounded-md mb-3"
              id="hero-text-content-desktop">
              <div>
                <h1 class="text-3xl xl:text-4xl font-bold mb-2 drop-shadow-lg" id="hero-title-desktop">
                  {heroTexts[0].title}
                </h1>
                <p class="text-md xl:text-lg mb-3 drop-shadow-md" id="hero-subtitle-desktop">
                  {heroTexts[0].subtitle}
                </p>
                <a href={heroTexts[0].linkUrl}
                  class="inline-block text-sm font-semibold pb-1 border-b-2 border-white hover:border-primary-300 hover:text-primary-300 transition-colors drop-shadow-sm"
                  id="hero-link-desktop">
                  {heroTexts[0].linkText} →
                </a>
              </div>
            </div>
            <div class="flex justify-center items-center gap-3 mb-4 px-2">
              <a href={`tel:${phoneNumber}`}
                class="flex items-center justify-center gap-2 bg-purple-600 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-purple-700 transition-colors shadow-md whitespace-nowrap">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5">
                  <path fill-rule="evenodd"
                    d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 15.352V16.5a1.5 1.5 0 0 1-1.5 1.5H15c-5.25 0-9.5-4.25-9.5-9.5V3.5Z"
                    clip-rule="evenodd" />
                </svg>
                Call Us {phoneDisplay}
              </a>
              <a href={modentoBookingLink} target="_blank" rel="noopener noreferrer"
                class="bg-secondary-500 text-white px-5 py-2.5 rounded-lg text-sm font-semibold hover:bg-secondary-600 transition-colors shadow-md whitespace-nowrap">
                Book Now
              </a>
            </div>
            <div class="swiper-pagination desktop-swiper-pagination !relative !bottom-auto pb-3 text-center"></div>
          </div>
        </div>
      </div>

      <div class="absolute z-20 right-6 xl:right-10 top-1/2 transform -translate-y-1/2">
        <div class="bg-white p-6 shadow-2xl rounded-lg w-[360px]">
          <div class="bg-purple-100 p-4 -m-6 mb-6 rounded-t-lg">
            <h2 class="text-xl font-bold text-purple-700 text-center">Request an Appointment</h2>
          </div>
          <form id="hero-request-form-desktop" class="space-y-3.5">
            <div>
              <label for="hero_full_name" class="block text-xs font-medium text-neutral-600 mb-1">Full Name</label>
              <input type="text" id="hero_full_name" name="fullName" placeholder="John Doe" required
                class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm" />
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label for="hero_email" class="block text-xs font-medium text-neutral-600 mb-1">Email</label>
                <input type="email" id="hero_email" name="email" placeholder="john@example.com" required
                  class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm" />
              </div>
              <div>
                <label for="hero_phone" class="block text-xs font-medium text-neutral-600 mb-1">Phone Number</label>
                <input type="tel" id="hero_phone" name="phone" placeholder="(555) 123-4567" required
                  class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm" />
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label for="hero_pref_date" class="block text-xs font-medium text-neutral-600 mb-1">Preferred Date</label>
                <input type="date" id="hero_pref_date" name="preferredDate"
                  class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm appearance-none" />
              </div>
              <div>
                <label for="hero_pref_time" class="block text-xs font-medium text-neutral-600 mb-1">Preferred Time</label>
                <select id="hero_pref_time" name="preferredTime"
                  class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm">
                  <option value="" disabled selected>Select a time</option>
                  <option value="morning">Morning</option>
                  <option value="afternoon">Afternoon</option>
                </select>
              </div>
            </div>
            <div>
              <label for="hero_reason" class="block text-xs font-medium text-neutral-600 mb-1">Reason for Visit</label>
              <select id="hero_reason" name="reasonForVisit"
                class="w-full px-3 py-2 border border-neutral-300 rounded-md focus:ring-2 focus:ring-purple-500 focus:border-purple-500 outline-none text-sm">
                <option value="" disabled selected>Select a reason</option>
                <option value="checkup">Routine Checkup & Cleaning</option>
                <option value="consultation">Consultation</option>
                <option value="whitening">Teeth Whitening</option>
                <option value="pain">Pain or Discomfort</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="flex items-start space-x-2 pt-1">
              <input id="hero_sms_consent" name="smsConsent" type="checkbox" required
                class="h-4 w-4 text-purple-600 border-neutral-300 rounded focus:ring-purple-500 mt-0.5" />
              <label for="hero_sms_consent" class="text-xs text-neutral-600">
                By checking this box you will be agreeing to receive text messages from Lilac Dental.
              </label>
            </div>
            <div class="mt-3 p-3 bg-neutral-100 border border-neutral-200 rounded-md text-center text-sm text-neutral-500">
              CAPTCHA verification would appear here.
            </div>
            <button type="submit"
              class="w-full bg-purple-600 text-white font-semibold py-2.5 px-6 rounded-md hover:bg-purple-700 transition-colors text-sm mt-2">
              Request Appointment
            </button>
          </form>
        </div>
      </div>
    </section>
  </div>
</Layout>

<script>
  const lambdaEndpoint = "https://7bvjump2trmhg2aemllzaoo5qu0ixytw.lambda-url.us-east-1.on.aws/";
  const heroTextsData = [
    { title: "Aesthetic Smiles", subtitle: "Renewing Dental Implants, Veneers, and Teeth Whitening Treatments", linkText: "See all Dental Treatments", linkUrl: "/services" },
    { title: "Your Family Dentist", subtitle: "Comprehensive care for all ages in a comfortable setting.", linkText: "Meet Our Team", linkUrl: "/about" },
    { title: "Advanced Dental Tech", subtitle: "Utilizing the latest technology for precise and comfortable care.", linkText: "Explore Technology", linkUrl: "/technology" }
  ];

  async function handleSubmit(event) {
    event.preventDefault();
    const formElement = event.target;
    const formData = new FormData(formElement);
    
    const data = {
      fullName: formData.get('fullName'),
      email: formData.get('email'),
      phone: formData.get('phone'),
      preferredDate: formData.get('preferredDate'),
      preferredTime: formData.get('preferredTime'),
      reasonForVisit: formData.get('reasonForVisit'),
      smsConsent: formData.get('smsConsent') === 'on',
    };

    const submitBtn = formElement.querySelector('button[type="submit"]');
    const originalBtnText = submitBtn.innerHTML;
    submitBtn.innerHTML = 'Submitting...';
    submitBtn.disabled = true;

    const existingMessage = formElement.querySelector('.form-submission-message');
    if (existingMessage) existingMessage.remove();

    try {
      const response = await fetch(lambdaEndpoint, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      const messageDiv = document.createElement('div');
      messageDiv.className = 'form-submission-message';
      messageDiv.style.marginTop = '10px';
      messageDiv.style.padding = '10px';
      messageDiv.style.borderRadius = '4px';
      messageDiv.style.fontSize = '14px';
      messageDiv.style.textAlign = 'center';

      if (response.ok) {
        messageDiv.style.backgroundColor = '#d4edda';
        messageDiv.style.color = '#155724';
        messageDiv.innerText = 'Thank you for your request. Your appointment request has been sent.';
        formElement.reset();
      } else {
        const errorData = await response.json().catch(() => ({ message: 'Submission failed. Please try again.' }));
        messageDiv.style.backgroundColor = '#f8d7da';
        messageDiv.style.color = '#721c24';
        messageDiv.innerText = errorData.message || 'Submission failed. Please try again.';
      }
      formElement.appendChild(messageDiv);
      setTimeout(() => messageDiv.remove(), 5000);
    } catch (error) {
      console.error('Error submitting form:', error);
      const messageDiv = document.createElement('div');
      // ... (error message styling) ...
      messageDiv.className = 'form-submission-message';
      messageDiv.style.marginTop = '10px';
      messageDiv.style.padding = '10px';
      messageDiv.style.borderRadius = '4px';
      messageDiv.style.fontSize = '14px';
      messageDiv.style.textAlign = 'center';
      messageDiv.style.backgroundColor = '#f8d7da';
      messageDiv.style.color = '#721c24';
      messageDiv.innerText = 'An error occurred. Please check your connection and try again.';
      formElement.appendChild(messageDiv);
      setTimeout(() => messageDiv.remove(), 5000);
    } finally {
      submitBtn.innerHTML = originalBtnText;
      submitBtn.disabled = false;
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    const desktopForm = document.getElementById('hero-request-form-desktop');
    if (desktopForm) {
      desktopForm.addEventListener('submit', handleSubmit);
    }

    const mobileRequestForm = document.getElementById('mobile-request-form');
    if (mobileRequestForm) {
      mobileRequestForm.addEventListener('submit', handleSubmit);
    }
    
    // JS to toggle the mobile "Request an Appointment" form section
    // YOU NEED TO CREATE/IDENTIFY THE ACTUAL TRIGGER ELEMENT (e.g., in your nav)
    // and ensure it has the id "trigger-mobile-request-form" or update the selector below.
    const triggerMobileRequestFormBtn = document.getElementById('trigger-mobile-request-form'); // This ID is an example.
    const mobileRequestFormSection = document.getElementById('mobile-request-appointment-form-section');
    const closeMobileRequestFormBtn = document.getElementById('close-mobile-request-form-btn');
    const mobileHeroContentWrapper = document.getElementById('mobile-hero-content-wrapper');
    const mobileLowerContentWrapper = document.getElementById('mobile-lower-content-wrapper');

    function showMobileRequestForm() {
        if (mobileRequestFormSection) {
            if (mobileRequestForm) {
                mobileRequestForm.reset();
                const existingMsg = mobileRequestForm.querySelector('.form-submission-message');
                if (existingMsg) existingMsg.remove();
                const submitBtn = mobileRequestForm.querySelector('button[type="submit"]');
                if (submitBtn) {
                    submitBtn.innerHTML = 'Send Request';
                    submitBtn.disabled = false;
                }
            }
            mobileRequestFormSection.classList.remove('hidden');
            mobileRequestFormSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
            if (mobileHeroContentWrapper) mobileHeroContentWrapper.classList.add('hidden');
            if (mobileLowerContentWrapper) mobileLowerContentWrapper.classList.add('hidden');
        }
    }

    function hideMobileRequestForm() {
        if (mobileRequestFormSection) {
            mobileRequestFormSection.classList.add('hidden');
            if (mobileHeroContentWrapper) mobileHeroContentWrapper.classList.remove('hidden');
            if (mobileLowerContentWrapper) mobileLowerContentWrapper.classList.remove('hidden');
        }
    }

    if (triggerMobileRequestFormBtn) { // This will only work if an element with this ID exists
        triggerMobileRequestFormBtn.addEventListener('click', showMobileRequestForm);
    }
    if (closeMobileRequestFormBtn) {
        closeMobileRequestFormBtn.addEventListener('click', hideMobileRequestForm);
    }

    if (typeof Swiper !== 'undefined') {
        const heroSwiperMobile = new Swiper('.hero-swiper-mobile', {
            loop: true,
            autoplay: { delay: 5000, disableOnInteraction: false },
            pagination: { el: '.mobile-swiper-pagination', clickable: true },
        });
        const heroSwiperDesktop = new Swiper('.hero-swiper-desktop', {
            loop: true,
            autoplay: { delay: 5000, disableOnInteraction: false },
            pagination: { el: '.desktop-swiper-pagination', clickable: true },
            on: {
                slideChange: function () {
                    const activeIndex = this.realIndex;
                    const currentTextData = heroTextsData[activeIndex % heroTextsData.length];
                    const titleEl = document.getElementById('hero-title-desktop');
                    const subtitleEl = document.getElementById('hero-subtitle-desktop');
                    const linkEl = document.getElementById('hero-link-desktop');
                    if (currentTextData && titleEl && subtitleEl && linkEl) {
                        titleEl.textContent = currentTextData.title;
                        subtitleEl.textContent = currentTextData.subtitle;
                        linkEl.textContent = `${currentTextData.linkText} →`;
                        linkEl.href = currentTextData.linkUrl;
                    }
                },
            },
        });
    }
    const marqueeContainer = document.querySelector('.marquee-container');
    if (marqueeContainer) {
      const marqueeContent = marqueeContainer.querySelector('.marquee-content');
      if (marqueeContent && marqueeContent.children.length > 0) {
        function animateMarquee() {
          const singleContentWidth = marqueeContent.children[0].offsetWidth + parseFloat(getComputedStyle(marqueeContent.children[0]).marginRight || '0');
          let currentPos = 0;
          function step() {
            currentPos -= 0.75;
            if (currentPos <= -singleContentWidth) {
              currentPos += singleContentWidth;
            }
            marqueeContent.style.transform = `translateX(${currentPos}px)`;
            requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }
        setTimeout(animateMarquee, 100); 
      }
    }
  });
</script>
