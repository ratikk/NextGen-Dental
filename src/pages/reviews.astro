---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import GoogleReviews from '../components/GoogleReviews.jsx';
import GoogleStats from '../components/GoogleStats.jsx';
import PatientSatisfaction from '../components/PatientSatisfaction.jsx';

const breadcrumbItems = [{ label: 'Reviews', href: '/reviews' }];
const yearsOfService = "15+";
---

<Layout title="Patient Reviews | Lilac Dental">
  <Hero
    title="Patient Reviews"
    subtitle="See what our patients say about their experience"
    imageUrl="https://images.pexels.com/photos/3845761/pexels-photo-3845761.jpeg"
  />

  <div class="container mx-auto px-4">
    <Breadcrumbs items={breadcrumbItems} />

    <div class="py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        <GoogleStats client:load />
        <div class="bg-white p-6 rounded-lg shadow-md text-center">
          <div class="text-3xl font-bold text-primary-600 mb-2">{yearsOfService}</div>
          <div class="text-neutral-600">Years of Service</div>
        </div>
        <PatientSatisfaction client:load />
      </div>

      <GoogleReviews client:load />

      <div class="bg-primary-50 p-8 rounded-lg mt-12">
        <h2 class="text-2xl font-bold mb-4">Share Your Experience</h2>
        <p class="text-neutral-600 mb-6">
          We value your feedback! Help us improve our services and let others know about your experience at Lilac Dental.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="https://g.page/r/your-google-review-link" target="_blank" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg">
            Write a Google Review
          </a>
          <a href="/book-appointment" class="inline-block bg-white text-primary-600 px-6 py-3 rounded-lg border border-primary-600">
            Book Appointment
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>

