---
import Layout from '../layouts/Layout.astro';
import Button from '../components/Button.astro';
import { clinicInfo } from '../utils/clinicInfo';

const businessHours = Object.entries(clinicInfo.hours).map(([day, hours]) => ({
  day,
  hours
}));

// Dynamic Title based on config
const pageTitle = `Contact Us | ${clinicInfo.name} - Dentist ${clinicInfo.address.city}, ${clinicInfo.address.state}`;
const metaDescription = `Get in touch with ${clinicInfo.name} for appointments, questions, or comments. Serving ${clinicInfo.address.city}, ${clinicInfo.address.state} and surrounding areas.`;

// Safety check: Ensure we have a phone number to display
const displayPhone = clinicInfo.displayPhone || clinicInfo.phone;
---

<Layout
  title={pageTitle}
  description={metaDescription}
>
  <!-- CLEAN, SLIM HEADER (No Stock Photo) -->
  <div class="bg-primary-900 text-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white" />
      </svg>
    </div>
    
    <div class="container mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">Contact {clinicInfo.name}</h1>
      <p class="text-primary-200 text-lg max-w-2xl mx-auto">
        We are here to help. Reach out to schedule an appointment or ask a question.
      </p>
    </div>
  </div>

  <!-- Breadcrumbs -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3">
      <nav class="flex text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li><a href="/" class="hover:text-primary-600">Home</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li class="text-gray-900 font-medium" aria-current="page">Contact</li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4">
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <section data-aos="fade-up">
          <div class="bg-white p-8 rounded-2xl shadow-lg border border-gray-100 h-full">
            <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">Send a Message</h2>

            <form id="contact-form" class="space-y-6">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="first-name" class="block text-sm font-medium text-gray-700 mb-1">First Name*</label>
                  <input
                    type="text"
                    id="first-name"
                    name="firstName"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-gray-50"
                  />
                </div>

                <div>
                  <label for="last-name" class="block text-sm font-medium text-gray-700 mb-1">Last Name*</label>
                  <input
                    type="text"
                    id="last-name"
                    name="lastName"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-gray-50"
                  />
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone Number*</label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    required
                    class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-gray-50"
                  />
                </div>
                <div>
                  <label for="dob" class="block text-sm font-medium text-gray-700 mb-1">Date of Birth</label>
                  <input
                    type="date"
                    id="dob"
                    name="dob"
                    class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-gray-50"
                  />
                </div>
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email Address*</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-gray-50"
                />
              </div>

              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1">How can we help you?*</label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  required
                  class="w-full px-4 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-primary-500 bg-gray-50"
                ></textarea>
              </div>

              <div class="flex items-start">
                <input
                  type="checkbox"
                  id="consent"
                  name="smsConsent"
                  required
                  class="mt-1 h-4 w-4 text-primary-600 focus:ring-primary-500 border-gray-300 rounded"
                />
                <label for="consent" class="ml-2 block text-sm text-gray-600">
                  By checking this box you will be agreeing to receive text messages from {clinicInfo.name}*
                </label>
              </div>

              <Button type="submit" variant="primary" class="w-full">
                Contact Us
              </Button>

              <p class="text-xs text-gray-500 mt-4 text-center">
                This form is protected by reCAPTCHA and the Google
                <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">Privacy Policy</a> and
                <a href="https://policies.google.com/terms" target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700">Terms of Service</a> apply.
              </p>
            </form>
          </div>
        </section>

        <!-- Contact Info & Hours -->
        <section data-aos="fade-up" data-aos-delay="100">
          <div class="bg-gray-50 p-8 rounded-2xl border border-gray-100 h-full flex flex-col justify-between">
            
            <!-- Info Header -->
            <div>
              <h3 class="text-2xl font-bold font-heading text-gray-800 mb-6">Contact Information</h3>
              <p class="text-gray-600 mb-8">
                Our office offers a full array of dental services. Simply call, or use the form to request an appointment.
              </p>
            
              <div class="space-y-6">
                <!-- Address -->
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-full bg-white border border-gray-200 shadow-sm flex items-center justify-center flex-shrink-0 text-primary-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-gray-800">Address</h4>
                    <p class="text-gray-600">{clinicInfo.address.line1}</p>
                    <p class="text-gray-600">{clinicInfo.address.city}, {clinicInfo.address.state} {clinicInfo.address.zip}</p>
                    <a href={clinicInfo.mapLink} target="_blank" class="text-primary-600 text-sm hover:underline mt-1 inline-block font-medium">Get Directions &rarr;</a>
                  </div>
                </div>

                <!-- Phone -->
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-full bg-white border border-gray-200 shadow-sm flex items-center justify-center flex-shrink-0 text-primary-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-gray-800">Phone</h4>
                    <p class="text-gray-600">
                      <a href={`tel:${clinicInfo.phone}`} class="hover:text-primary-600 transition-colors font-medium">{displayPhone}</a>
                    </p>
                  </div>
                </div>

                <!-- Email -->
                <div class="flex items-start gap-4">
                  <div class="w-10 h-10 rounded-full bg-white border border-gray-200 shadow-sm flex items-center justify-center flex-shrink-0 text-primary-600">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="font-bold text-gray-800">Email</h4>
                    <p class="text-gray-600">
                      <a href={`mailto:${clinicInfo.email}`} class="hover:text-primary-600 transition-colors font-medium">{clinicInfo.email}</a>
                    </p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Office Hours Table -->
            <div class="mt-8 bg-white p-6 rounded-xl border border-gray-100 shadow-sm">
              <h4 class="font-bold text-gray-800 mb-4 flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                Office Hours
              </h4>
              <ul class="space-y-3">
                {businessHours.map(({ day, hours }) => (
                  <li class="flex justify-between text-sm">
                    <span class="text-gray-500 font-medium">{day}</span>
                    <span class="text-gray-900 font-bold">{hours}</span>
                  </li>
                ))}
              </ul>
            </div>

          </div>
        </section>
      </div>

      <!-- Map Section -->
      <section class="mt-16 rounded-2xl overflow-hidden shadow-lg border border-gray-200" data-aos="fade-up">
        <div class="w-full h-[450px] bg-gray-100">
          <iframe 
            width="100%" 
            height="100%" 
            style="border:0;" 
            loading="lazy" 
            allowfullscreen 
            referrerpolicy="no-referrer-when-downgrade"
            src={`https://maps.google.com/maps?q=${encodeURIComponent(clinicInfo.address.full)}&t=&z=15&ie=UTF8&iwloc=&output=embed`}>
          </iframe>
        </div>
      </section>

    </div>
  </div>
</Layout>

<script>
  import { submitForm } from '../utils/forms';

  const formElement = document.getElementById('contact-form') as HTMLFormElement | null;

  function displayFormMessage(formEl: HTMLFormElement, message: string, status: 'success' | 'error') {
    const existingMessage = formEl.querySelector('.form-submission-message');
    if (existingMessage) {
      existingMessage.remove();
    }

    const messageDiv = document.createElement('div');
    const baseClasses = 'mt-4 p-3 rounded-md text-sm text-center form-submission-message';
    const successClasses = 'bg-green-100 text-green-800 border border-green-200';
    const errorClasses = 'bg-red-100 text-red-800 border border-red-200';

    messageDiv.className = `${baseClasses} ${status === 'success' ? successClasses : errorClasses}`;
    messageDiv.innerText = message;

    const submitBtn = formEl.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.parentNode?.insertBefore(messageDiv, submitBtn);
    }
  }

  async function handleFormSubmit(event: Event) {
    event.preventDefault();
    if (!formElement) return;

    const submitBtn = formElement.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (!submitBtn) return;

    const originalBtnHTML = submitBtn.innerHTML;

    submitBtn.disabled = true;
    submitBtn.innerHTML = `<span>Submitting...</span>`;
    displayFormMessage(formElement, '', 'success');

    try {
      const formData = new FormData(formElement);
      const data = {
        firstName: formData.get('firstName') as string,
        lastName: formData.get('lastName') as string,
        phone: formData.get('phone') as string,
        email: formData.get('email') as string,
        dob: formData.get('dob') as string,
        message: formData.get('message') as string,
        smsConsent: formData.get('smsConsent') === 'on',
        formType: 'contact' as const,
      };

      await submitForm(data);

      displayFormMessage(formElement, 'Thank you! Your message has been sent successfully.', 'success');
      formElement.reset();

    } catch (error) {
      console.error('Contact form submission error:', error);
      displayFormMessage(formElement, `Error: ${error.message || 'Something went wrong.'}`, 'error');

    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalBtnHTML;
    }
  }

  if (formElement) {
    formElement.addEventListener('submit', handleFormSubmit);
  }
</script>
