---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import { clinicInfo } from '../../utils/clinicInfo';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Sedation Dentistry', href: '/services/sedation-dentistry' },
];

// --- SEO: SEDATION PROCEDURE SCHEMA ---
const sedationSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Sedation Dentistry",
  "procedureType": "NoninvasiveProcedure",
  "description": "Anxiety-free dental treatments using Nitrous Oxide (laughing gas) and oral conscious sedation for patient comfort.",
  "provider": {
    "@type": "Dentist",
    "name": clinicInfo.name,
    "telephone": clinicInfo.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": clinicInfo.address.line1,
      "addressLocality": clinicInfo.address.city,
      "addressRegion": clinicInfo.address.state,
      "postalCode": clinicInfo.address.zip,
      "addressCountry": "US"
    }
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://lilacdentalaustintx.com/services/sedation-dentistry"
  }
};
---

<Layout
  title="Sedation Dentist Austin, TX (78747) | Anxiety-Free Dentistry | NextGen Dental"
  description="Overcome dental anxiety with gentle sedation dentistry at NextGen Dental in South Austin. We offer Nitrous Oxide (laughing gas) for a relaxing, stress-free experience."
  serviceSchema={sedationSchema}
>
  <!-- CLEAN, SLIM HEADER -->
  <div class="bg-primary-900 text-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white" />
      </svg>
    </div>
    
    <div class="container mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">Sedation Dentistry</h1>
      <p class="text-primary-200 text-lg max-w-2xl mx-auto">
        Relax. We make your dental visit comfortable, calm, and anxiety-free.
      </p>
    </div>
  </div>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3">
      <nav class="flex text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li><a href="/" class="hover:text-primary-600">Home</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li><a href="/services" class="hover:text-primary-600">Services</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li class="text-gray-900 font-medium" aria-current="page">Sedation</li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4">
      
      <!-- Introduction -->
      <section class="mb-16 max-w-3xl mx-auto text-center" data-aos="fade-up">
        <h2 class="text-3xl font-bold font-heading text-gray-800 mb-6">Fear the Dentist? You Are Not Alone.</h2>
        <p class="text-lg text-gray-600 mb-6">
          Dental anxiety prevents thousands of people in <strong>Austin</strong> from getting the care they need. At <strong>{clinicInfo.name}</strong>, we offer a judgment-free zone. We understand that fear is real, and we have solutions to help you relax.
        </p>
        <p class="text-lg text-gray-600">
          With modern sedation options like Nitrous Oxide (Laughing Gas), your appointment can feel like a breeze. You can finally fix your teeth without the stress.
        </p>
      </section>

      <!-- Sedation Options -->
      <section class="mb-16 max-w-5xl mx-auto" data-aos="fade-up">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
          <div class="bg-primary-50 p-8 rounded-2xl border border-primary-100">
            <h3 class="text-2xl font-bold text-primary-800 mb-4 flex items-center gap-3">
              <span class="text-3xl">😌</span> Nitrous Oxide (Laughing Gas)
            </h3>
            <p class="text-gray-700 mb-4">
              This is our most popular option for mild to moderate anxiety. You inhale a sweet-smelling gas through a small mask. Within minutes, you feel light, happy, and relaxed.
            </p>
            <ul class="space-y-2">
              <li class="flex items-center gap-2 text-gray-600 text-sm">
                <span class="text-green-500 font-bold">✓</span> Takes effect immediately
              </li>
              <li class="flex items-center gap-2 text-gray-600 text-sm">
                <span class="text-green-500 font-bold">✓</span> You remain conscious and in control
              </li>
              <li class="flex items-center gap-2 text-gray-600 text-sm">
                <span class="text-green-500 font-bold">✓</span> Wears off instantly (you can drive yourself home!)
              </li>
            </ul>
          </div>

          <div class="bg-white p-8 rounded-2xl border border-gray-200 shadow-sm">
            <h3 class="text-2xl font-bold text-gray-800 mb-4 flex items-center gap-3">
              <span class="text-3xl">💊</span> Oral Conscious Sedation
            </h3>
            <p class="text-gray-700 mb-4">
              For patients with higher anxiety, we can prescribe a pill to be taken about an hour before your appointment. This provides a deeper state of relaxation.
            </p>
            <ul class="space-y-2">
              <li class="flex items-center gap-2 text-gray-600 text-sm">
                <span class="text-green-500 font-bold">✓</span> Deeper relaxation (you may doze off)
              </li>
              <li class="flex items-center gap-2 text-gray-600 text-sm">
                <span class="text-green-500 font-bold">✓</span> Little to no memory of the procedure
              </li>
              <li class="flex items-center gap-2 text-gray-600 text-sm">
                <span class="text-yellow-500 font-bold">⚠</span> Requires a driver to take you home
              </li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Who is this for? -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6 text-center">Is Sedation Right for You?</h2>
        <div class="bg-gray-50 p-8 rounded-xl">
          <p class="text-gray-600 mb-6 text-center">
            Sedation dentistry is an excellent choice if you experience:
          </p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full"></div>
              <span class="text-gray-700">Fear of needles or drills</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full"></div>
              <span class="text-gray-700">Sensitive gag reflex</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full"></div>
              <span class="text-gray-700">Difficulty getting numb</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full"></div>
              <span class="text-gray-700">Need for multiple procedures in one visit</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full"></div>
              <span class="text-gray-700">Painful or sensitive teeth</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 bg-primary-500 rounded-full"></div>
              <span class="text-gray-700">Traumatic past dental experiences</span>
            </div>
          </div>
        </div>
      </section>

      <!-- FAQs -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6 text-center">Common Questions</h2>
        
        <div class="space-y-4">
          <div class="bg-white border border-gray-200 rounded-lg p-5">
            <h3 class="font-bold text-gray-800 mb-2">Is sedation dentistry safe?</h3>
            <p class="text-gray-600 text-sm">Yes. We monitor your vital signs throughout the entire procedure to ensure your safety. Nitrous oxide is one of the safest sedatives available.</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-lg p-5">
            <h3 class="font-bold text-gray-800 mb-2">Will I fall asleep?</h3>
            <p class="text-gray-600 text-sm">With Nitrous Oxide, you will stay awake but feel very relaxed. With Oral Sedation, you may feel drowsy enough to doze off, but you can be easily woken up.</p>
          </div>
          <div class="bg-white border border-gray-200 rounded-lg p-5">
            <h3 class="font-bold text-gray-800 mb-2">Does insurance cover it?</h3>
            <p class="text-gray-600 text-sm">It depends on your plan. Nitrous oxide is often an out-of-pocket cost, but it is very affordable. We can verify your benefits before your appointment.</p>
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="max-w-3xl mx-auto text-center" data-aos="fade-up">
        <div class="bg-primary-50 p-8 rounded-xl border border-primary-100">
          <h2 class="text-2xl font-bold font-heading text-gray-800 mb-4">Don't Let Fear Stop You</h2>
          <p class="text-gray-600 mb-6">
            Get the healthy smile you deserve without the stress. Schedule a consultation at NextGen Dental in South Austin today.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button
              href={clinicInfo.booking.url}
              text="Book Appointment"
              variant="primary"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
            />
            <Button
              href={`tel:${clinicInfo.phone}`}
              text="Call to Discuss Options"
              variant="outline"
              size="lg"
            />
          </div>
        </div>
      </section>

    </div>
  </div>
</Layout>
