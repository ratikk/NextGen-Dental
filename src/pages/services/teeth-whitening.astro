---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import { clinicInfo } from '../../utils/clinicInfo';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Teeth Whitening', href: '/services/teeth-whitening' },
];

// --- SEO: COSMETIC PROCEDURE SCHEMA ---
const whiteningSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Professional Teeth Whitening",
  "procedureType": "CosmeticProcedure",
  "bodyLocation": "Teeth",
  "description": "Professional in-office and take-home teeth whitening treatments to remove stains and brighten smiles.",
  "provider": {
    "@type": "Dentist",
    "name": clinicInfo.name,
    "telephone": clinicInfo.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": clinicInfo.address.line1,
      "addressLocality": clinicInfo.address.city,
      "addressRegion": clinicInfo.address.state,
      "postalCode": clinicInfo.address.zip,
      "addressCountry": "US"
    }
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://lilacdentalaustintx.com/services/teeth-whitening"
  }
};
---

<Layout
  title="Professional Teeth Whitening in Austin, TX | NextGen Dental"
  description="Get a brighter, whiter smile with professional teeth whitening at NextGen Dental in South Austin (78747). Safe, effective Zoom! treatments for long-lasting results."
  serviceSchema={whiteningSchema}
>
  <!-- CLEAN, SLIM HEADER -->
  <div class="bg-primary-900 text-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white" />
      </svg>
    </div>
    
    <div class="container mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">Professional Teeth Whitening</h1>
      <p class="text-primary-200 text-lg max-w-2xl mx-auto">
        Transform your smile with safe and effective whitening treatments.
      </p>
    </div>
  </div>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3">
      <nav class="flex text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li><a href="/" class="hover:text-primary-600">Home</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li><a href="/services" class="hover:text-primary-600">Services</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li class="text-gray-900 font-medium" aria-current="page">Whitening</li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <!-- Introduction -->
      <section class="mb-16 max-w-3xl mx-auto text-center" data-aos="fade-up">
        <h2 class="text-3xl font-bold font-heading text-gray-800 mb-6">Brighten Your Smile in South Austin</h2>
        <p class="text-lg text-gray-600 mb-6">
          A bright, radiant smile can boost your confidence and make a lasting first impression. At <strong>{clinicInfo.name}</strong>, serving residents of <strong>South Austin</strong>, Buda, and the 78747 area, we offer professional teeth whitening solutions that are far superior to over-the-counter strips.
        </p>
        <p class="text-lg text-gray-600 mb-6">
          Whether you have staining from coffee, wine, or just natural aging, our professional-grade whitening treatments are customized to your sensitivity level to ensure a comfortable experience and dazzling results.
        </p>
      </section>

      <!-- Treatment Options -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">Our Whitening Options</h2>

        <div class="space-y-6">
          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">In-Office Power Whitening</h3>
            <p class="text-gray-600 mb-4">
              Perfect for patients in Austin who want immediate results for a wedding, interview, or special event.
            </p>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>Professional-strength gel applied by our experts</li>
              <li>Dramatic results in just one visit (about an hour)</li>
              <li>Gum protection measures to prevent irritation</li>
              <li>Walk out with a noticeably whiter smile</li>
            </ul>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">Custom Take-Home Kits</h3>
            <p class="text-gray-600 mb-4">
              Whiten comfortably at home with trays custom-molded to your unique bite.
            </p>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>Trays fitted precisely at our Austin office</li>
              <li>Professional-strength gel (stronger than store brands)</li>
              <li>Whiten at your own pace (30 minutes a day)</li>
              <li>Excellent for maintenance and touch-ups</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- Benefits -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">Why Choose Professional Whitening?</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-primary-50 p-6 rounded-lg">
            <h3 class="text-xl font-bold text-gray-800 mb-3">Safety & Comfort</h3>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>Supervised by Dr. K & Dr. Yanala</li>
              <li>Custom trays prevent gel leakage on gums</li>
              <li>Formulas designed to minimize sensitivity</li>
              <li>Safe for enamel</li>
            </ul>
          </div>

          <div class="bg-primary-50 p-6 rounded-lg">
            <h3 class="text-xl font-bold text-gray-800 mb-3">Superior Results</h3>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>Remove deep, stubborn stains</li>
              <li>Even, consistent whitening</li>
              <li>Longer lasting than drug-store kits</li>
              <li>Customized shade goals</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- The Process -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">The Whitening Process</h2>

        <div class="space-y-6">
          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">1. Shade Assessment</h3>
            <p class="text-gray-600">
              We start by evaluating your current tooth shade and discussing your goals. We check for existing restorations (crowns/fillings) as these do not whiten like natural enamel.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">2. Cleaning & Preparation</h3>
            <p class="text-gray-600">
              A quick professional cleaning removes surface plaque, ensuring the whitening gel can penetrate the enamel evenly for the best results.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">3. Treatment Application</h3>
            <p class="text-gray-600">
              For in-office visits, we apply a protective barrier to your gums and then apply the high-concentration gel. For home kits, we take impressions to create your custom trays.
            </p>
          </div>
        </div>
      </section>

      <!-- FAQs -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">Common Questions</h2>

        <div class="space-y-4">
          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-2">How long do results last?</h3>
            <p class="text-gray-600">
              Results typically last 6 months to 2 years, depending on your lifestyle (coffee, tea, smoking). We recommend keeping your custom trays for inexpensive touch-ups.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-2">Is it safe for my enamel?</h3>
            <p class="text-gray-600">
              Yes. Professional whitening products use ingredients that are proven safe for tooth enamel when used as directed by a dentist.
            </p>
          </div>
        </div>
      </section>

      <!-- Call to Action -->
      <section class="max-w-3xl mx-auto text-center" data-aos="fade-up">
        <div class="bg-primary-50 p-8 rounded-lg">
          <h2 class="text-2xl font-bold font-heading text-gray-800 mb-4">Ready for a Brighter Smile?</h2>
          <p class="text-gray-600 mb-6">
            Visit us in South Austin (78747) for a consultation. Let's reveal the bright, confident smile you deserve!
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button
              href={clinicInfo.booking.zocdoc}
              text="Book Whitening"
              variant="primary"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
            />
            <Button
              href={`tel:${clinicInfo.phone}`}
              text="Call Us"
              variant="outline"
              size="lg"
            />
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
