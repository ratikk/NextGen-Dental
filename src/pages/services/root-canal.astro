---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import { clinicInfo } from '../../utils/clinicInfo';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Root Canal', href: '/services/root-canal' },
];

// --- SEO: MEDICAL PROCEDURE SCHEMA ---
const rootCanalSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Root Canal Treatment",
  "procedureType": "SurgicalProcedure",
  "bodyLocation": "Tooth",
  "description": "Endodontic therapy to remove infected pulp and save the natural tooth.",
  "provider": {
    "@type": "Dentist",
    "name": clinicInfo.name,
    "telephone": clinicInfo.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": clinicInfo.address.line1,
      "addressLocality": clinicInfo.address.city,
      "addressRegion": clinicInfo.address.state,
      "postalCode": clinicInfo.address.zip,
      "addressCountry": "US"
    }
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://lilacdentalaustintx.com/services/root-canal"
  }
};
---

<Layout
  title="Root Canal Treatment in Austin, TX (78747) | NextGen Dental"
  description="Save your natural tooth with gentle root canal therapy at NextGen Dental in South Austin. Relief for tooth pain and infection near Buda."
  serviceSchema={rootCanalSchema}
>
  <!-- CLEAN, SLIM HEADER -->
  <div class="bg-primary-900 text-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white" />
      </svg>
    </div>
    
    <div class="container mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">Root Canal Therapy</h1>
      <p class="text-primary-200 text-lg max-w-2xl mx-auto">
        Save your natural teeth with modern endodontic treatment.
      </p>
    </div>
  </div>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3">
      <nav class="flex text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li><a href="/" class="hover:text-primary-600">Home</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li><a href="/services" class="hover:text-primary-600">Services</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li class="text-gray-900 font-medium" aria-current="page">Root Canal</li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <!-- Introduction -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-3xl font-bold font-heading text-gray-800 mb-6">Expert Endodontic Care in South Austin</h2>
        <p class="text-lg text-gray-600 mb-6">
          If you are experiencing severe tooth pain or sensitivity, you may need a root canal. At <strong>{clinicInfo.name}</strong>, located in South Austin (78747), we perform gentle, modern root canal therapy to save your natural tooth and eliminate pain.
        </p>
        <p class="text-lg text-gray-600 mb-6">
          Despite its reputation, a root canal is a straightforward procedure that relieves pain caused by deep decay or infection. Our compassionate team ensures your comfort every step of the way.
        </p>
      </section>

      <!-- When It's Needed -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">Signs You May Need Treatment</h2>

        <div class="bg-gray-50 p-6 rounded-lg mb-8">
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 flex-shrink-0">⚠️</div>
              <div>
                <strong class="text-gray-800">Severe Tooth Pain:</strong>
                <p class="text-gray-600">Pain when chewing or applying pressure.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 flex-shrink-0">❄️</div>
              <div>
                <strong class="text-gray-800">Temperature Sensitivity:</strong>
                <p class="text-gray-600">Lingering pain after eating hot or cold foods.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 flex-shrink-0">🌑</div>
              <div>
                <strong class="text-gray-800">Tooth Discoloration:</strong>
                <p class="text-gray-600">Darkening of the tooth due to nerve damage.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-8 h-8 rounded-full bg-primary-100 flex items-center justify-center text-primary-600 flex-shrink-0">🔴</div>
              <div>
                <strong class="text-gray-800">Swollen Gums:</strong>
                <p class="text-gray-600">Tenderness or a pimple-like bump on the gums.</p>
              </div>
            </li>
          </ul>
        </div>
      </section>

      <!-- The Procedure -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">What to Expect During Your Visit</h2>

        <div class="space-y-8">
          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">1. Diagnosis & Imaging</h3>
            <p class="text-gray-600">
              We use advanced digital X-rays to pinpoint the infection and plan your treatment precisely.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">2. Numbing & Comfort</h3>
            <p class="text-gray-600">
              We apply local anesthesia to numb the area completely. You will feel pressure, but not pain.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">3. Cleaning the Root</h3>
            <p class="text-gray-600">
              We create a tiny opening to remove the infected pulp, clean the canals, and disinfect the area.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">4. Sealing & Restoration</h3>
            <p class="text-gray-600">
              The tooth is filled with a biocompatible material. Finally, we place a crown to restore the tooth's strength and appearance.
            </p>
          </div>
        </div>
      </section>

      <!-- Call to Action -->
      <section class="max-w-3xl mx-auto text-center" data-aos="fade-up">
        <div class="bg-primary-50 p-8 rounded-lg">
          <h2 class="text-2xl font-bold font-heading text-gray-800 mb-4">Save Your Smile Today</h2>
          <p class="text-gray-600 mb-6">
            Don't let tooth pain worsen. Contact NextGen Dental in Austin immediately to schedule an evaluation.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button
              href={clinicInfo.booking.zocdoc}
              text="Book Appointment"
              variant="primary"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
            />
            <Button
              href={`tel:${clinicInfo.phone}`}
              text="Call Us"
              variant="outline"
              size="lg"
            />
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
