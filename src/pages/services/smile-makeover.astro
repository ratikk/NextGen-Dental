---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const breadcrumbItems = [
  { label: 'Services', href: '/services' },
  { label: 'Smile Makeover', href: '/services/smile-makeover' }
];
---

<Layout 
  title="Smile Makeover | Services | Smile Dental Clinic"
  description="Transform your smile with our comprehensive smile makeover services. Customized treatment plans to achieve your dream smile."
>
  <Hero 
    title="Smile Makeover"
    subtitle="Comprehensive smile transformation tailored to your goals"
    imageUrl="https://images.pexels.com/photos/3762453/pexels-photo-3762453.jpeg"
  />
  
  <div class="container mx-auto px-4">
    <Breadcrumbs items={breadcrumbItems} />
    
    <article class="max-w-4xl mx-auto py-12">
      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6">What is a Smile Makeover?</h2>
        <p class="text-neutral-600 mb-4">
          A smile makeover is a comprehensive treatment plan that combines multiple cosmetic dental procedures to enhance the appearance of your smile. Each makeover is customized to address your specific concerns and achieve your desired results.
        </p>
        <div class="grid md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">Common Procedures</h3>
            <ul class="space-y-3 text-neutral-600">
              <li>• Teeth whitening</li>
              <li>• Porcelain veneers</li>
              <li>• Dental bonding</li>
              <li>• Crown placement</li>
              <li>• Gum contouring</li>
            </ul>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">Addresses Issues Like</h3>
            <ul class="space-y-3 text-neutral-600">
              <li>• Discolored teeth</li>
              <li>• Gaps and spacing</li>
              <li>• Chipped or worn teeth</li>
              <li>• Misaligned teeth</li>
              <li>• Uneven gum line</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6">The Smile Makeover Process</h2>
        <div class="bg-white p-6 rounded-lg shadow-md">
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">1.</span>
              <div>
                <strong>Initial Consultation:</strong>
                <p class="text-neutral-600">Discussion of your goals and comprehensive examination.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">2.</span>
              <div>
                <strong>Digital Smile Design:</strong>
                <p class="text-neutral-600">Preview your new smile with advanced imaging technology.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">3.</span>
              <div>
                <strong>Treatment Planning:</strong>
                <p class="text-neutral-600">Development of your customized treatment sequence.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">4.</span>
              <div>
                <strong>Procedure Implementation:</strong>
                <p class="text-neutral-600">Coordinated execution of planned treatments.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">5.</span>
              <div>
                <strong>Final Refinements:</strong>
                <p class="text-neutral-600">Fine-tuning for optimal aesthetics and function.</p>
              </div>
            </li>
          </ul>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6">Benefits and Considerations</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">Benefits</h3>
            <ul class="space-y-3 text-neutral-600">
              <li>• Enhanced appearance</li>
              <li>• Improved confidence</li>
              <li>• Better oral function</li>
              <li>• Long-lasting results</li>
              <li>• Comprehensive solution</li>
            </ul>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">Important Considerations</h3>
            <ul class="space-y-3 text-neutral-600">
              <li>• Treatment timeline</li>
              <li>• Maintenance requirements</li>
              <li>• Investment planning</li>
              <li>• Recovery periods</li>
              <li>• Long-term care</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="bg-primary-50 p-8 rounded-lg">
        <h2 class="text-2xl font-bold mb-4">Transform Your Smile</h2>
        <p class="text-neutral-600 mb-6">
          Ready to achieve the smile you've always dreamed of? Schedule a consultation to discuss your smile makeover options.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/book-appointment" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors text-center">
            Schedule Consultation
          </a>
          <a href="/contact" class="inline-block bg-white text-primary-600 px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors text-center border border-primary-600">
            Contact Us
          </a>
        </div>
      </section>
    </article>
  </div>
</Layout>