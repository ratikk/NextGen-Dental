---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import { clinicInfo } from '../../utils/clinicInfo';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Services', href: '/services' },
  { label: 'Dental Implants', href: '/services/dental-implants' },
];

// --- SEO: SURGICAL PROCEDURE SCHEMA ---
const implantSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalProcedure",
  "name": "Dental Implants",
  "procedureType": "SurgicalProcedure",
  "bodyLocation": "Mouth",
  "description": "Permanent replacement of missing teeth using titanium posts and porcelain crowns.",
  "provider": {
    "@type": "Dentist",
    "name": clinicInfo.name,
    "telephone": clinicInfo.phone,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": clinicInfo.address.line1,
      "addressLocality": clinicInfo.address.city,
      "addressRegion": clinicInfo.address.state,
      "postalCode": clinicInfo.address.zip,
      "addressCountry": "US"
    }
  },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "availability": "https://schema.org/InStock",
    "url": "https://lilacdentalaustintx.com/services/dental-implants",
    "description": "Includes implant post, abutment, and crown. Financing available."
  }
};
---

<Layout
  title="Dental Implants in Austin, TX (78747) | NextGen Dental"
  description="Restore your smile with permanent dental implants at NextGen Dental in South Austin. We offer single tooth replacement, bridges, and implant dentures near Buda."
  serviceSchema={implantSchema}
>
  <!-- CLEAN, SLIM HEADER -->
  <div class="bg-primary-900 text-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white" />
      </svg>
    </div>
    
    <div class="container mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">Dental Implants</h1>
      <p class="text-primary-200 text-lg max-w-2xl mx-auto">
        Permanent, natural-looking tooth replacement solutions in Austin.
      </p>
    </div>
  </div>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3">
      <nav class="flex text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li><a href="/" class="hover:text-primary-600">Home</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li><a href="/services" class="hover:text-primary-600">Services</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li class="text-gray-900 font-medium" aria-current="page">Implants</li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4">
      <!-- Introduction -->
      <section class="mb-16 max-w-3xl mx-auto text-center" data-aos="fade-up">
        <h2 class="text-3xl font-bold font-heading text-gray-800 mb-6">Restore Your Smile in South Austin</h2>
        <p class="text-lg text-gray-600 mb-6">
          Missing teeth can affect not just your smile, but your ability to eat, speak, and live with confidence.
          At <strong>{clinicInfo.name}</strong>, located conveniently off <strong>Interstate 35</strong> in Austin (78747), we specialize in restoring smiles with state-of-the-art dental implants.
        </p>
        <p class="text-lg text-gray-600 mb-6">
          Dental implants are the gold standard for tooth replacement. Unlike dentures that slip or bridges that require grinding down healthy teeth, implants provide a permanent, stable foundation that looks and feels exactly like your natural teeth.
        </p>
      </section>

      <!-- Benefits -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">Why Choose Implants?</h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-primary-50 p-6 rounded-lg">
            <h3 class="text-xl font-bold text-gray-800 mb-3">Functional Benefits</h3>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>Restore natural biting force (eat steak, apples!)</li>
              <li>Prevent bone loss & facial sagging</li>
              <li>No slipping or adhesives needed</li>
              <li>Protect adjacent healthy teeth</li>
              <li>Speech improvement</li>
            </ul>
          </div>

          <div class="bg-primary-50 p-6 rounded-lg">
            <h3 class="text-xl font-bold text-gray-800 mb-3">Aesthetic Benefits</h3>
            <ul class="list-disc list-inside text-gray-600 space-y-2">
              <li>Look identical to natural teeth</li>
              <li>Preserve your natural face shape</li>
              <li>Smile with total confidence</li>
              <li>No visible metal hooks or clasps</li>
              <li>Custom-shaded to match your smile</li>
            </ul>
          </div>
        </div>
      </section>

      <!-- The Process -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">The Implant Process at NextGen Dental</h2>

        <div class="space-y-6">
          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">1. Consultation & 3D Scanning</h3>
            <p class="text-gray-600">
              We start with a comprehensive exam at our Austin office using advanced 3D CBCT imaging to evaluate your bone density and plan the precise placement of your implant.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">2. Implant Placement</h3>
            <p class="text-gray-600">
              The titanium post is gently placed into the jawbone. This procedure is typically performed under local anesthesia, and most patients report minimal discomfort.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">3. Healing & Osseointegration</h3>
            <p class="text-gray-600">
              Over 3-6 months, the implant fuses with your natural bone. This biological bond provides a rock-solid foundation for your new tooth.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">4. Your New Smile</h3>
            <p class="text-gray-600">
              Once healed, we attach a custom-crafted porcelain crown. You leave our office with a complete, beautiful, and fully functional smile.
            </p>
          </div>
        </div>
      </section>

      <!-- Types of Implants -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">Implant Solutions We Offer</h2>

        <div class="space-y-6">
          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">Single Tooth Replacement</h3>
            <p class="text-gray-600">
              Perfect for replacing one missing tooth without grinding down neighboring teeth for a bridge.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">Implant-Supported Bridges</h3>
            <p class="text-gray-600">
              Ideal for replacing 3 or more teeth in a row using just two implants for support.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-3">Implant Dentures (All-on-4)</h3>
            <p class="text-gray-600">
              Secure loose dentures permanently. No more messy adhesives or slipping while you talk.
            </p>
          </div>
        </div>
      </section>

      <!-- FAQs -->
      <section class="mb-16 max-w-3xl mx-auto" data-aos="fade-up">
        <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6">Common Questions</h2>

        <div class="space-y-4">
          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-2">How long do implants last?</h3>
            <p class="text-gray-600">
              With proper care (brushing, flossing, and regular checkups), the titanium implant screw can last a lifetime. The porcelain crown may need replacement after 15-20 years due to normal wear.
            </p>
          </div>

          <div class="bg-white shadow-sm border border-gray-100 rounded-lg p-6">
            <h3 class="text-xl font-bold text-gray-800 mb-2">Does insurance cover implants?</h3>
            <p class="text-gray-600">
              Many insurance plans now cover a portion of the implant procedure. We also accept CareCredit and offer flexible financing options to make your smile restoration affordable.
            </p>
          </div>
        </div>
      </section>

      <!-- Call to Action -->
      <section class="max-w-3xl mx-auto text-center" data-aos="fade-up">
        <div class="bg-primary-50 p-8 rounded-lg">
          <h2 class="text-2xl font-bold font-heading text-gray-800 mb-4">Ready to Restore Your Smile?</h2>
          <p class="text-gray-600 mb-6">
            Schedule a consultation at our Austin office to find out if dental implants are right for you.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button
              href={clinicInfo.booking.url}
              text="Book Consultation"
              variant="primary"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
            />
            <Button
              href={`tel:${clinicInfo.phone}`}
              text="Call Us"
              variant="outline"
              size="lg"
            />
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
