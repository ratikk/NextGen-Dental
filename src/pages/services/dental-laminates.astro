---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const breadcrumbItems = [
  { label: 'Services', href: '/services' },
  { label: 'Dental Laminates', href: '/services/dental-laminates' }
];
---

<Layout 
  title="Dental Laminates | Services | Smile Dental Clinic"
  description="Transform your smile with ultra-thin dental laminates. Learn about this minimally invasive cosmetic dental solution."
>
  <Hero 
    title="Dental Laminates"
    subtitle="Ultra-thin porcelain shells for a beautiful, natural-looking smile"
    imageUrl="https://images.pexels.com/photos/3845761/pexels-photo-3845761.jpeg"
  />
  
  <div class="container mx-auto px-4">
    <Breadcrumbs items={breadcrumbItems} />
    
    <article class="max-w-4xl mx-auto py-12">
      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6">What Are Dental Laminates?</h2>
        <p class="text-neutral-600 mb-4">
          Dental laminates are ultra-thin shells of porcelain that are bonded to the front surface of teeth. They are similar to veneers but typically require less tooth reduction, making them a more conservative option for smile enhancement.
        </p>
        <div class="grid md:grid-cols-2 gap-8 mt-8">
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">Ideal For</h3>
            <ul class="space-y-3 text-neutral-600">
              <li>• Slightly discolored teeth</li>
              <li>• Minor chips or cracks</li>
              <li>• Small gaps between teeth</li>
              <li>• Slightly misaligned teeth</li>
              <li>• Preserving natural tooth structure</li>
            </ul>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">Advantages</h3>
            <ul class="space-y-3 text-neutral-600">
              <li>• Minimal tooth preparation</li>
              <li>• Natural-looking results</li>
              <li>• Stain-resistant</li>
              <li>• Long-lasting</li>
              <li>• Reversible procedure</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6">The Laminate Process</h2>
        <div class="bg-white p-6 rounded-lg shadow-md">
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">1.</span>
              <div>
                <strong>Consultation & Planning:</strong>
                <p class="text-neutral-600">Discussion of your goals and digital smile design planning.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">2.</span>
              <div>
                <strong>Minimal Preparation:</strong>
                <p class="text-neutral-600">Little to no removal of tooth structure required.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">3.</span>
              <div>
                <strong>Custom Fabrication:</strong>
                <p class="text-neutral-600">Creation of your personalized porcelain laminates.</p>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-primary-600 font-bold">4.</span>
              <div>
                <strong>Bonding:</strong>
                <p class="text-neutral-600">Precise placement and bonding of laminates.</p>
              </div>
            </li>
          </ul>
        </div>
      </section>

      <section class="mb-12">
        <h2 class="text-2xl font-bold mb-6">Caring for Your Laminates</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">Daily Care</h3>
            <ul class="space-y-3 text-neutral-600">
              <li>• Brush twice daily</li>
              <li>• Floss regularly</li>
              <li>• Use non-abrasive toothpaste</li>
              <li>• Avoid staining foods/drinks</li>
              <li>• Don't use teeth as tools</li>
            </ul>
          </div>
          
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">Long-term Maintenance</h3>
            <ul class="space-y-3 text-neutral-600">
              <li>• Regular dental checkups</li>
              <li>• Professional cleanings</li>
              <li>• Wear nightguard if recommended</li>
              <li>• Address any issues promptly</li>
              <li>• Follow care instructions</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="bg-primary-50 p-8 rounded-lg">
        <h2 class="text-2xl font-bold mb-4">Transform Your Smile</h2>
        <p class="text-neutral-600 mb-6">
          Ready to enhance your smile with minimal intervention? Schedule a consultation to learn if dental laminates are right for you.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/book-appointment" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors text-center">
            Schedule Consultation
          </a>
          <a href="/contact" class="inline-block bg-white text-primary-600 px-6 py-3 rounded-lg hover:bg-primary-50 transition-colors text-center border border-primary-600">
            Contact Us
          </a>
        </div>
      </section>
    </article>
  </div>
</Layout>