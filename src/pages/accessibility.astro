---
import Layout from '../layouts/Layout.astro';
import { clinicInfo } from '../utils/clinicInfo';

// Sidebar Sections
const sections = [
  { id: 'commitment', title: 'Our Commitment', icon: '♿' },
  { id: 'standards', title: 'Standards (WCAG)', icon: '✅' },
  { id: 'measures', title: 'Measures Taken', icon: '🛠️' },
  { id: 'compatibility', title: 'Compatibility', icon: '🖥️' },
  { id: 'feedback', title: 'Feedback & Contact', icon: '📞' }
];

const lastUpdated = new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout
  title="Accessibility Statement | NextGen Dental Austin"
  description={`Accessibility Statement for ${clinicInfo.name}. Our commitment to digital inclusion for all patients.`}
>
  <!-- Decorative Header Background -->
  <div class="bg-primary-900 text-white py-20 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white" />
      </svg>
    </div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <span class="inline-block py-1 px-3 rounded-full bg-primary-800 border border-primary-700 text-xs font-medium tracking-wider uppercase mb-4">
        Legal Documentation
      </span>
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">Accessibility Statement</h1>
      <p class="text-primary-200 text-lg max-w-2xl mx-auto">
        We are committed to ensuring our dental care is accessible to everyone.
      </p>
      <p class="text-sm text-primary-300 mt-4">Last Updated: {lastUpdated}</p>
    </div>
  </div>

  <div class="bg-gray-50 min-h-screen py-16">
    <div class="container mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-12 max-w-7xl mx-auto">
        
        <!-- SIDEBAR NAVIGATION -->
        <aside class="hidden lg:block w-1/4">
          <div class="sticky top-24 bg-white rounded-xl shadow-lg p-6 border border-gray-100">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4">Table of Contents</h3>
            <nav class="space-y-1">
              {sections.map(section => (
                <a 
                  href={`#${section.id}`} 
                  class="block px-3 py-2 text-sm font-medium text-gray-600 hover:text-primary-600 hover:bg-primary-50 rounded-lg transition-colors"
                >
                  <span class="mr-2">{section.icon}</span> {section.title}
                </a>
              ))}
            </nav>
          </div>
        </aside>

        <!-- MAIN CONTENT -->
        <div class="w-full lg:w-3/4">
          <div class="bg-white rounded-2xl shadow-xl border border-gray-100 p-8 md:p-12">
            
            <!-- Intro -->
            <div class="prose prose-lg text-gray-600 mb-12 border-b border-gray-100 pb-8">
              <p class="lead text-xl text-gray-800 font-medium">
                <strong>{clinicInfo.name}</strong> is committed to ensuring digital accessibility for people with disabilities. We are continually improving the user experience for everyone and applying the relevant accessibility standards.
              </p>
            </div>

            <!-- Sections Loop -->
            <div class="space-y-16">
              
              <section id="commitment" class="scroll-mt-32">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-3xl">♿</span>
                  <h2 class="text-2xl font-bold text-gray-900">Our Commitment</h2>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  We believe that every person has the right to live with dignity, equality, comfort, and independence. We have invested resources to help ensure that our website is easier to use and more accessible for people with disabilities, with the strong belief that website accessibility efforts assist all users and that every person has the right to engage with our dental services.
                </p>
              </section>

              <section id="standards" class="scroll-mt-32">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-3xl">✅</span>
                  <h2 class="text-2xl font-bold text-gray-900">Conformance Status</h2>
                </div>
                <div class="bg-green-50 p-6 rounded-lg border-l-4 border-green-500">
                  <p class="text-gray-800 font-medium">
                    We strive to adhere to the Web Content Accessibility Guidelines (WCAG) 2.1 Level AA.
                  </p>
                </div>
                <p class="text-gray-600 mt-4 leading-relaxed">
                  The <a href="https://www.w3.org/WAI/standards-guidelines/wcag/" target="_blank" rel="noopener" class="text-primary-600 hover:underline">Web Content Accessibility Guidelines (WCAG)</a> defines requirements for designers and developers to improve accessibility for people with disabilities. It defines three levels of conformance: Level A, Level AA, and Level AAA. {clinicInfo.name} is partially conformant with WCAG 2.1 level AA. Partially conformant means that some parts of the content may not fully conform to the accessibility standard, though we are working to address this.
                </p>
              </section>

              <section id="measures" class="scroll-mt-32">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-3xl">🛠️</span>
                  <h2 class="text-2xl font-bold text-gray-900">Measures Taken</h2>
                </div>
                <p class="text-gray-600 leading-relaxed mb-4">
                  We employ the following measures to ensure accessibility:
                </p>
                <ul class="list-disc pl-6 space-y-2 text-gray-600">
                  <li>Include accessibility as part of our mission statement.</li>
                  <li>Ensure sufficient color contrast for readability.</li>
                  <li>Provide text alternatives (alt text) for non-text content like images.</li>
                  <li>Ensure the website is navigable via keyboard.</li>
                </ul>
              </section>

              <section id="compatibility" class="scroll-mt-32">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-3xl">🖥️</span>
                  <h2 class="text-2xl font-bold text-gray-900">Technical Specifications</h2>
                </div>
                <p class="text-gray-600 leading-relaxed">
                  Accessibility of the {clinicInfo.name} website relies on the following technologies to work with the particular combination of web browser and any assistive technologies or plugins installed on your computer:
                </p>
                <div class="flex gap-3 mt-4">
                  <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded text-sm font-bold">HTML</span>
                  <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded text-sm font-bold">WAI-ARIA</span>
                  <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded text-sm font-bold">CSS</span>
                  <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded text-sm font-bold">JavaScript</span>
                </div>
              </section>

              <section id="feedback" class="scroll-mt-32 bg-gray-900 text-white p-8 rounded-xl">
                <div class="flex items-center gap-3 mb-4">
                  <span class="text-3xl">📞</span>
                  <h2 class="text-2xl font-bold text-white">Feedback & Contact</h2>
                </div>
                <p class="text-gray-300 mb-6">
                  We welcome your feedback on the accessibility of our website. Please let us know if you encounter accessibility barriers:
                </p>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <span class="block text-gray-400 text-sm uppercase tracking-wider mb-1">Phone</span>
                    <a href={`tel:${clinicInfo.phone}`} class="text-lg font-medium hover:text-primary-300 transition-colors">{clinicInfo.displayPhone || clinicInfo.phone}</a>
                  </div>
                  <div>
                    <span class="block text-gray-400 text-sm uppercase tracking-wider mb-1">Email</span>
                    <a href={`mailto:${clinicInfo.email}`} class="text-lg font-medium hover:text-primary-300 transition-colors">{clinicInfo.email}</a>
                  </div>
                  <div class="md:col-span-2">
                    <span class="block text-gray-400 text-sm uppercase tracking-wider mb-1">Office Address</span>
                    <span class="text-lg font-medium">{clinicInfo.address.full}</span>
                  </div>
                </div>
                <p class="text-sm text-gray-400 mt-6 pt-6 border-t border-gray-700">
                  We try to respond to feedback within 2 business days.
                </p>
              </section>

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
