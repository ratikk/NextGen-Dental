---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout title="Book an Appointment | Smile Dental Clinic">
  <Hero title="Schedule Your Appointment" subtitle="We're looking forward to seeing you at our clinic"
    imageUrl="https://images.pexels.com/photos/3845757/pexels-photo-3845757.jpeg?auto=compress&cs=tinysrgb&dpr=2&h=750&w=1260"
    buttonText="" />

  <section class="py-16">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">
          <!-- Appointment Form -->
          <div class="lg:col-span-3">
            <div class="bg-white p-8 rounded-lg shadow-md">
              <h2 class="text-2xl font-bold mb-6">Request an Appointment</h2>

              <form id="appointment-form" class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label for="first-name" class="block text-sm font-medium text-neutral-700 mb-1">First Name *</label>
                    <input type="text" id="first-name" name="first-name" required
                      class="w-full px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" />
                  </div>

                  <div>
                    <label for="last-name" class="block text-sm font-medium text-neutral-700 mb-1">Last Name *</label>
                    <input type="text" id="last-name" name="last-name" required
                      class="w-full px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" />
                  </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">Email Address *</label>
                    <input type="email" id="email" name="email" required
                      class="w-full px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" />
                  </div>

                  <div>
                    <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone Number *</label>
                    <input type="tel" id="phone" name="phone" required
                      class="w-full px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" />
                  </div>
                </div>

                <div>
                  <label for="service" class="block text-sm font-medium text-neutral-700 mb-1">Service Interested In
                    *</label>
                  <select id="service" name="service" required
                    class="w-full px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors">
                    <option value="">Please select a service</option>
                    <option value="cleaning">Dental Cleaning & Checkup</option>
                    <option value="whitening">Teeth Whitening</option>
                    <option value="implants">Dental Implants</option>
                    <option value="invisalign">Invisalign</option>
                    <option value="veneers">Dental Veneers</option>
                    <option value="emergency">Emergency Dental Care</option>
                    <option value="other">Other</option>
                  </select>
                </div>

                <div>
                  <label for="date-preference" class="block text-sm font-medium text-neutral-700 mb-1">Preferred Date
                    *</label>
                  <input type="date" id="date-preference" name="date-preference" required
                    class="w-full px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors" />
                </div>

                <div>
                  <label for="time-preference" class="block text-sm font-medium text-neutral-700 mb-1">Preferred Time
                    *</label>
                  <select id="time-preference" name="time-preference" required
                    class="w-full px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors">
                    <option value="">Please select a time</option>
                    <option value="morning">Morning (8AM - 12PM)</option>
                    <option value="afternoon">Afternoon (12PM - 4PM)</option>
                    <option value="evening">Evening (4PM - 6PM)</option>
                  </select>
                </div>

                <div>
                  <label for="message" class="block text-sm font-medium text-neutral-700 mb-1">Additional Notes</label>
                  <textarea id="message" name="message" rows="4"
                    class="w-full px-4 py-2 border border-neutral-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors resize-none"></textarea>
                </div>

                <div>
                  <label for="insurance" class="block text-sm font-medium text-neutral-700 mb-1">Do you have
                    insurance?</label>
                  <div class="flex gap-4 mt-1">
                    <label class="flex items-center gap-2">
                      <input type="radio" name="insurance" value="yes"
                        class="h-4 w-4 text-primary-600 border-neutral-300 focus:ring-primary-500" />
                      <span>Yes</span>
                    </label>
                    <label class="flex items-center gap-2">
                      <input type="radio" name="insurance" value="no"
                        class="h-4 w-4 text-primary-600 border-neutral-300 focus:ring-primary-500" />
                      <span>No</span>
                    </label>
                  </div>
                </div>

                <div>
                  <label for="new-patient" class="block text-sm font-medium text-neutral-700 mb-1">Are you a new
                    patient?</label>
                  <div class="flex gap-4 mt-1">
                    <label class="flex items-center gap-2">
                      <input type="radio" name="new-patient" value="yes"
                        class="h-4 w-4 text-primary-600 border-neutral-300 focus:ring-primary-500" />
                      <span>Yes</span>
                    </label>
                    <label class="flex items-center gap-2">
                      <input type="radio" name="new-patient" value="no"
                        class="h-4 w-4 text-primary-600 border-neutral-300 focus:ring-primary-500" />
                      <span>No</span>
                    </label>
                  </div>
                </div>

                <div class="flex items-start">
                  <input type="checkbox" id="privacy" name="privacy" required
                    class="mt-1.5 h-4 w-4 text-primary-600 border-neutral-300 rounded focus:ring-primary-500" />
                  <label for="privacy" class="ml-2 text-sm text-neutral-600">
                    I consent to having this website store my information for appointment scheduling. See our <a
                      href="/privacy-policy" class="text-primary-600 hover:underline">privacy policy</a> for more
                    information.
                  </label>
                </div>

                <div id="captcha" class="mb-2">
                  <!-- Captcha would be rendered here in production -->
                  <div class="bg-neutral-100 p-4 rounded-md text-center text-neutral-500 text-sm">
                    CAPTCHA verification would appear here
                  </div>
                </div>

                <button type="submit"
                  class="w-full bg-primary-600 hover:bg-primary-700 text-white font-medium py-3 px-4 rounded-lg transition-colors">
                  Request Appointment
                </button>
              </form>
            </div>
          </div>

          <!-- Information Sidebar -->
          <div class="lg:col-span-2">
            <div class="bg-white p-8 rounded-lg shadow-md mb-6">
              <h3 class="text-xl font-semibold mb-4">Book By Phone</h3>
              <p class="text-neutral-600 mb-4">
                If you prefer to schedule your appointment by phone, please call us during our business hours.
              </p>
              <a href="tel:+1234567890" class="flex items-center gap-2 text-primary-600 font-medium mt-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24"
                  stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                (123) 456-7890
              </a>
            </div>

            <div class="bg-white p-8 rounded-lg shadow-md mb-6">
              <h3 class="text-xl font-semibold mb-4">Office Hours</h3>
              <ul class="space-y-2 text-neutral-600">
                <li class="flex justify-between">
                  <span>Monday:</span>
                  <span>9:00 AM to 5:00 PM</span>
                </li>
                <li class="flex justify-between">
                  <span>Tuesday:</span>
                  <span>Closed</span>
                </li>
                <li class="flex justify-between">
                  <span>Wednesday:</span>
                  <span>9:00 AM to 5:00 PM</span>
                </li>
                <li class="flex justify-between">
                  <span>Thursday:</span>
                  <span>9:00 AM to 5:00 PM</span>
                </li>
                <li class="flex justify-between">
                  <span>Friday:</span>
                  <span>10:00 AM to 2:00 PM</span>
                </li>
                <li class="flex justify-between">
                  <span>Saturday:</span>
                  <span>9:00 AM to 2:00 PM</span>
                </li>
                <li class="flex justify-between">
                  <span>Sunday:</span>
                  <span>Closed</span>
                </li>
              </ul>
            </div>


            <div class="bg-white p-8 rounded-lg shadow-md">
              <h3 class="text-xl font-semibold mb-4">What to Expect</h3>
              <p class="text-neutral-600 mb-3">
                After submitting your request, our team will contact you to confirm your appointment time. Please bring
                the following to your appointment:
              </p>
              <ul class="list-disc pl-5 text-neutral-600 space-y-1">
                <li>Photo ID</li>
                <li>Insurance card (if applicable)</li>
                <li>List of current medications</li>
                <li>Completed new patient forms (if sent to you)</li>
              </ul>
              <p class="text-neutral-600 mt-3">
                If you need to reschedule or cancel, please contact us at least 24 hours in advance.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  // Form submission handling
  const appointmentForm = document.getElementById('appointment-form');

  appointmentForm?.addEventListener('submit', (e) => {
    e.preventDefault();

    // In a real implementation, you would send the form data to your server
    // This is just a simple example showing form validation and feedback

    // Get form data
    const formData = new FormData(e.target as HTMLFormElement);
    const formDataObj = Object.fromEntries(formData.entries());

    // This would include captcha verification in production

    // Show success message
    alert('Thank you! Your appointment request has been submitted. We will contact you shortly to confirm your appointment.');

    // Reset form
    (e.target as HTMLFormElement).reset();
  });
</script>
