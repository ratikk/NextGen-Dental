---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import ModernGallery from '../components/ModernGallery.tsx';
import { clinicInfo } from '../utils/clinicInfo';
import { GALLERY_IMAGES } from '../utils/images';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Smile Gallery', href: '/smile-gallery' },
];

const galleryItems = [
  {
    title: "Professional Teeth Whitening",
    category: "Whitening",
    before: GALLERY_IMAGES.whiteningCase1.before,
    after: GALLERY_IMAGES.whiteningCase1.after,
  },
  {
    title: "Zoom Whitening Treatment",
    category: "Whitening",
    before: GALLERY_IMAGES.whiteningCase2.before,
    after: GALLERY_IMAGES.whiteningCase2.after,
  },
  {
    title: "Composite Fillings Restoration",
    category: "Restorative",
    before: GALLERY_IMAGES.fillingsCase1.before,
    after: GALLERY_IMAGES.fillingsCase1.after,
  },
  {
    title: "Single Dental Implant",
    category: "Implants",
    before: GALLERY_IMAGES.implantCase1.before,
    after: GALLERY_IMAGES.implantCase1.after,
  },
  {
    title: "Multiple Dental Implants",
    category: "Implants",
    before: GALLERY_IMAGES.implantCase2.before,
    after: GALLERY_IMAGES.implantCase2.after,
  },
  {
    title: "Porcelain Veneers - Full Smile",
    category: "Veneers",
    before: GALLERY_IMAGES.veneersCase1.before,
    after: GALLERY_IMAGES.veneersCase1.after,
  },
  {
    title: "Veneers for Discolored Teeth",
    category: "Veneers",
    before: GALLERY_IMAGES.veneersCase2.before,
    after: GALLERY_IMAGES.veneersCase2.after,
  },
  {
    title: "Orthodontic Treatment",
    category: "Orthodontics",
    before: GALLERY_IMAGES.orthodonticsCase1.before,
    after: GALLERY_IMAGES.orthodonticsCase1.after,
  },
  {
    title: "Dental Crowns",
    category: "Crowns",
    before: GALLERY_IMAGES.crownsCase1.before,
    after: GALLERY_IMAGES.crownsCase1.after,
  },
  {
    title: "Complete Smile Makeover",
    category: "Cosmetic",
    before: GALLERY_IMAGES.cosmeticCase1.before,
    after: GALLERY_IMAGES.cosmeticCase1.after,
  },
];
---

<Layout
  title="Smile Gallery | Before & After Transformations | NextGen Dental Austin"
  description="See real patient results. Explore before and after photos of implants, veneers, and whitening at NextGen Dental in Austin, TX."
>
  <!-- CLEAN, SLIM HEADER (No Big Image) -->
  <div class="bg-primary-900 text-white pt-32 pb-16 relative overflow-hidden">
    <div class="absolute inset-0 opacity-10">
      <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
        <path d="M0 100 C 20 0 50 0 100 100 Z" fill="white" />
      </svg>
    </div>
    
    <div class="container mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">Smile Transformations</h1>
      <p class="text-primary-200 text-lg max-w-2xl mx-auto">
        Real patients. Real results. See what modern dentistry can do for you.
      </p>
    </div>
  </div>

  <!-- Breadcrumbs -->
  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3">
      <nav class="flex text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li><a href="/" class="hover:text-primary-600">Home</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li class="text-gray-900 font-medium" aria-current="page">Smile Gallery</li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="py-16 bg-gradient-to-b from-white to-gray-50">
    <div class="container mx-auto px-4">

      <!-- Intro Section -->
      <div class="text-center max-w-3xl mx-auto mb-16" data-aos="fade-up">
        <h2 class="text-3xl md:text-4xl font-bold font-heading text-gray-900 mb-4">
          Transform Your Smile
        </h2>
        <p class="text-lg text-gray-600 leading-relaxed">
          Explore our collection of real patient transformations. Each smile tells a unique story of confidence restored through advanced dental care.
        </p>
      </div>

      <!-- Gallery Grid -->
      <section class="mb-20" data-aos="fade-up">
        <ModernGallery client:load items={galleryItems} />
      </section>

      <!-- CTA Section -->
      <section class="max-w-3xl mx-auto text-center" data-aos="fade-up">
        <div class="bg-primary-50 p-8 rounded-2xl border border-primary-100 shadow-sm">
          <h2 class="text-3xl font-bold font-heading text-gray-900 mb-4">
            Ready to Start Your Transformation?
          </h2>
          <p class="text-gray-600 mb-8 text-lg">
            Schedule a consultation to discuss your smile goals and learn how we can help you achieve similar results.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button
              href={clinicInfo.booking.url}
              text="Book Consultation"
              variant="primary"
              size="lg"
              target="_blank"
              rel="noopener noreferrer"
            />
            <Button
              href={`tel:${clinicInfo.phone}`}
              text="Call Us"
              variant="outline"
              size="lg"
              class="bg-white hover:bg-gray-50"
            />
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
