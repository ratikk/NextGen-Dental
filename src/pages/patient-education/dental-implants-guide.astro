---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { clinicInfo } from '../../utils/clinicInfo';
// ✅ ADD THIS IMPORT
import { HERO_IMAGES } from '../../utils/images';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Patient Education', href: '/patient-information' },
  { label: 'Dental Implants Guide', href: '/patient-education/dental-implants-guide' },
];
---

<Layout
  title="Patient Guide to Dental Implants | NextGen Dental Austin"
  description="Learn about dental implants, their benefits, procedure steps, and recovery process from the dental experts at NextGen Dental in Austin, TX."
>
  <Hero
    title="Dental Implants Guide"
    subtitle="Everything you need to know about permanent tooth replacement"
    images={[HERO_IMAGES.dental2]} 
    height="md"
  />
  {/* 👆 FIXED: Used HERO_IMAGES.dental2 instead of string path */}

  <Breadcrumbs items={breadcrumbItems} />

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <article class="prose prose-lg prose-primary mx-auto">
        <h2>Understanding Dental Implants</h2>
        <p>
          Dental implants are a long-term solution for replacing missing teeth. Unlike dentures, which rest on the gums, implants are placed directly into the jawbone, acting as an artificial tooth root.
        </p>
        
        <h3>Why Choose Implants?</h3>
        <ul>
          <li><strong>Natural Look and Feel:</strong> They function just like your own teeth.</li>
          <li><strong>Durability:</strong> With proper care, they can last a lifetime.</li>
          <li><strong>Bone Health:</strong> They stimulate the jawbone, preventing bone loss that occurs when teeth are missing.</li>
        </ul>

        <h3>The Process</h3>
        <p>
          The process typically involves three main phases:
        </p>
        <ol>
          <li><strong>Placement:</strong> The implant post is surgically placed into the jawbone.</li>
          <li><strong>Healing:</strong> Over a few months, the bone heals around the implant (osseointegration).</li>
          <li><strong>Restoration:</strong> A custom crown is attached to the implant, completing your smile.</li>
        </ol>

        <div class="bg-primary-50 p-6 rounded-lg not-prose mt-8 text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Have Questions?</h3>
          <p class="text-gray-600 mb-4">
            Schedule a consultation at {clinicInfo.name} to see if implants are right for you.
          </p>
          <a 
            href="/contact" 
            class="inline-block bg-primary-600 text-white px-6 py-2 rounded-md hover:bg-primary-700 transition-colors"
          >
            Contact Us
          </a>
        </div>
      </article>
    </div>
  </div>
</Layout>
