---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import { clinicInfo } from '../../utils/clinicInfo';
// ✅ ADD THIS IMPORT
import { HERO_IMAGES } from '../../utils/images';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Patient Education', href: '/patient-information' },
  { label: 'Orthodontics Guide', href: '/patient-education/orthodontics-guide' },
];
---

<Layout
  title="Patient Guide to Orthodontics | Braces & Aligners | NextGen Dental"
  description="Learn about orthodontic treatments, including braces and clear aligners, from the dental experts at NextGen Dental in Austin, TX."
>
  <Hero
    title="Understanding Orthodontics"
    subtitle="Straightening smiles for health and confidence"
    images={[HERO_IMAGES.dental5]} 
    height="md"
  />
  {/* 👆 FIXED: Used HERO_IMAGES.dental5 instead of string path */}

  <Breadcrumbs items={breadcrumbItems} />

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <article class="prose prose-lg prose-primary mx-auto">
        <h2>More Than Just a Straight Smile</h2>
        <p>
          Orthodontics is the branch of dentistry that specializes in the diagnosis, prevention, and treatment of dental and facial irregularities. While many people associate orthodontics with cosmetic improvements, straight teeth are also healthier teeth.
        </p>
        
        <h3>Why Straighten Teeth?</h3>
        <ul>
          <li><strong>Easier Cleaning:</strong> Crooked or crowded teeth are harder to clean, leading to higher risks of cavities and gum disease.</li>
          <li><strong>Better Bite:</strong> Misaligned bites can cause abnormal wear of tooth surfaces, difficulty in chewing, and stress on bone and gum tissue.</li>
          <li><strong>Jaw Health:</strong> Proper alignment can relieve stress on the jaw joints (TMJ).</li>
        </ul>

        <h3>Treatment Options</h3>
        <p>
          Modern dentistry offers more choices than ever before:
        </p>
        <ul>
          <li><strong>Traditional Braces:</strong> The most common fixed appliance, consisting of bands, wires, and brackets. They are highly effective for complex movements.</li>
          <li><strong>Clear Aligners (Invisalign):</strong> A series of clear, removable trays that gradually move teeth. They are virtually invisible and allow for easier eating and cleaning.</li>
        </ul>

        <div class="bg-primary-50 p-6 rounded-lg not-prose mt-8 text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Considering Orthodontics?</h3>
          <p class="text-gray-600 mb-4">
            Schedule a consultation at {clinicInfo.name} to discuss whether braces or clear aligners are right for you.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button 
              href="/contact" 
              text="Book Consultation" 
              variant="primary"
            />
          </div>
        </div>
      </article>
    </div>
  </div>
</Layout>
