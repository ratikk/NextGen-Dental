---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import { clinicInfo } from '../../utils/clinicInfo';
// ✅ ADD THIS IMPORT
import { HERO_IMAGES } from '../../utils/images';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Patient Education', href: '/patient-information' },
  { label: 'Root Canal Guide', href: '/patient-education/root-canal-guide' },
];
---

<Layout
  title="Patient Guide to Root Canal Therapy | NextGen Dental Austin"
  description="Learn about root canal treatment, what to expect during the procedure, and recovery tips from the dental experts at NextGen Dental in Austin, TX."
>
  <Hero
    title="Root Canal Therapy Guide"
    subtitle="Saving your natural teeth"
    images={[HERO_IMAGES.dental2]} 
    height="md"
  />
  {/* 👆 FIXED: Used HERO_IMAGES.dental2 instead of string path */}

  <Breadcrumbs items={breadcrumbItems} />

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <article class="prose prose-lg prose-primary mx-auto">
        <h2>What is a Root Canal?</h2>
        <p>
          A root canal is a treatment used to repair and save a tooth that is badly decayed or becomes infected. During a root canal procedure, the nerve and pulp are removed and the inside of the tooth is cleaned and sealed. Without treatment, the tissue surrounding the tooth will become infected and abscesses may form.
        </p>
        
        <h3>Why Would I Need a Root Canal?</h3>
        <p>
          A tooth's nerve and pulp can become irritated, inflamed, and infected due to deep decay, repeated dental procedures on a tooth, large fillings, a crack or chip in the tooth, or trauma to the face.
        </p>

        <h3>What are the Signs?</h3>
        <ul>
          <li>Severe toothache pain upon chewing or application of pressure</li>
          <li>Prolonged sensitivity (pain) to heat or cold temperatures (after the heat or cold has been removed)</li>
          <li>Discoloration (darkening) of the tooth</li>
          <li>Swelling and tenderness in nearby gums</li>
          <li>A persistent or recurring pimple on the gums</li>
        </ul>

        <h3>The Procedure</h3>
        <p>
          Root canal treatment is highly successful; the procedure has more than a 95% success rate. Many teeth fixed with a root canal can last a lifetime.
        </p>
        <ol>
          <li><strong>Anesthesia:</strong> Local anesthesia is administered to numb the tooth and surrounding area.</li>
          <li><strong>Access:</strong> An opening is made through the crown of the tooth into the pulp chamber.</li>
          <li><strong>Cleaning:</strong> The pulp is removed, and the root canals are cleaned, enlarged, and shaped.</li>
          <li><strong>Filling:</strong> The root canals are filled and sealed.</li>
          <li><strong>Restoration:</strong> A crown is usually placed over the tooth to protect and restore it to full function.</li>
        </ol>

        <div class="bg-primary-50 p-6 rounded-lg not-prose mt-8 text-center">
          <h3 class="text-xl font-bold text-gray-900 mb-2">Experiencing Tooth Pain?</h3>
          <p class="text-gray-600 mb-4">
            Don't wait until it gets worse. Contact {clinicInfo.name} immediately.
          </p>
          <div class="flex flex-wrap justify-center gap-4">
            <Button 
              href="/contact" 
              text="Book Appointment" 
              variant="primary"
            />
            <Button
              href={`tel:${clinicInfo.phone}`}
              text="Call Us"
              variant="outline"
            />
          </div>
        </div>
      </article>
    </div>
  </div>
</Layout>
