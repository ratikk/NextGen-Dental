---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { clinicInfo } from '../../utils/clinicInfo';
// ✅ ADD THIS IMPORT
import { HERO_IMAGES } from '../../utils/images';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Patient Education', href: '/patient-information' },
  { label: 'FAQs', href: '/patient-education/faq' },
];

const faqs = [
  {
    category: "General",
    items: [
      {
        q: "Do you accept new patients?",
        a: `Yes! We are currently welcoming new patients of all ages to ${clinicInfo.name}. Whether you need a routine checkup or restorative work, we are here to help.`
      },
      {
        q: "What insurance do you accept?",
        a: "We accept most major PPO dental insurance plans, including Delta, Cigna, MetLife, and Aetna. We also offer a complimentary benefits check before your appointment."
      },
      {
        q: "What if I have a dental emergency?",
        a: `We set aside time daily for emergency appointments. If you are in pain, please call us immediately at ${clinicInfo.displayPhone}.`
      }
    ]
  },
  {
    category: "Procedures",
    items: [
      {
        q: "How often should I get a checkup?",
        a: "The American Dental Association recommends visiting your dentist every six months for regular checkups and routine teeth cleanings to keep your teeth and gums healthy."
      },
      {
        q: "Are dental x-rays safe?",
        a: "Yes. We use modern digital X-rays which use up to 90% less radiation than traditional film X-rays. They are safe and vital for diagnosing issues we can't see with the naked eye."
      }
    ]
  }
];
---

<Layout
  title="Dental FAQs | Common Questions Answered | NextGen Dental"
  description="Find answers to common dental questions about procedures, insurance, emergency care, and more at NextGen Dental in Austin, TX."
>
  <Hero
    title="Frequently Asked Questions"
    subtitle="Answers to your common dental health questions"
    images={[HERO_IMAGES.dental2]} 
    height="md"
  />
  {/* 👆 FIXED: Used HERO_IMAGES.dental2 instead of string path */}

  <Breadcrumbs items={breadcrumbItems} />

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      
      <div class="space-y-12">
        {faqs.map((section) => (
          <div>
            <h2 class="text-2xl font-bold font-heading text-gray-800 mb-6 border-b border-gray-200 pb-2">
              {section.category}
            </h2>
            <div class="space-y-4">
              {section.items.map((item) => (
                <details class="group bg-gray-50 rounded-lg p-4 border border-gray-100 cursor-pointer open:bg-white open:shadow-md transition-all duration-200">
                  <summary class="font-bold text-gray-800 flex justify-between items-center list-none select-none">
                    {item.q}
                    <span class="text-primary-600 transform group-open:rotate-180 transition-transform duration-200">
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                      </svg>
                    </span>
                  </summary>
                  <p class="mt-3 text-gray-600 leading-relaxed border-t border-gray-100 pt-3">
                    {item.a}
                  </p>
                </details>
              ))}
            </div>
          </div>
        ))}
      </div>

      <div class="mt-16 bg-primary-900 text-white rounded-xl p-8 text-center">
        <h3 class="text-2xl font-bold mb-4">Still have questions?</h3>
        <p class="text-primary-200 mb-8">
          Our friendly team is happy to answer any specific questions you may have about your dental care or insurance coverage.
        </p>
        <a 
          href="/contact" 
          class="inline-block bg-white text-primary-900 font-bold px-8 py-3 rounded-md hover:bg-primary-50 transition-colors"
        >
          Contact Us
        </a>
      </div>

    </div>
  </div>
</Layout>
