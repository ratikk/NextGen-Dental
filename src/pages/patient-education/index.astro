---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';

const breadcrumbItems = [
  { label: 'Patient Education', href: '/patient-education' }
];

const resources = [
  {
    title: "Oral Health Basics",
    items: [
      {
        title: "Oral Hygiene Basics",
        description: "Learn proper brushing and flossing techniques.",
        url: "/patient-education/oral-hygiene-basics"
      },
      {
        title: "Before & After Gallery",
        description: "View real results from our dental treatments.",
        url: "/patient-education/before-after"
      },
      {
        title: "Why Are My Gums Bleeding",
        description: "Understanding causes and solutions for bleeding gums.",
        url: "/patient-education/why-are-my-gums-bleeding"
      }
    ]
  },
  {
    title: "Treatment Information",
    items: [
      {
        title: "Do I Need a Root Canal",
        description: "Signs you might need root canal treatment.",
        url: "/patient-education/do-i-need-a-root-canal"
      },
      {
        title: "Options For Replacing Missing Teeth",
        description: "Compare different tooth replacement options.",
        url: "/patient-education/options-for-replacing-missing-teeth"
      },
      {
        title: "Will I Need a Bone Graft",
        description: "Understanding bone grafts for dental implants.",
        url: "/patient-education/will-i-need-a-bone-graft-for-dental-implants"
      }
    ]
  },
  {
    title: "Cosmetic & Orthodontic Care",
    items: [
      {
        title: "What Can I Do To Improve My Smile",
        description: "Explore options for enhancing your smile.",
        url: "/patient-education/what-can-i-do-to-improve-my-smile"
      },
      {
        title: "Which Is Better: Invisalign or Braces",
        description: "Compare orthodontic treatment options.",
        url: "/patient-education/which-is-better-invisalign-or-braces"
      },
      {
        title: "Alternative to Braces for Teens",
        description: "Modern options for teen orthodontics.",
        url: "/patient-education/alternative-to-braces-for-teens"
      }
    ]
  },
  {
    title: "Dental Concerns",
    items: [
      {
        title: "When Is Tooth Extraction Necessary",
        description: "Understanding when teeth need to be removed.",
        url: "/patient-education/when-is-a-tooth-extraction-necessary"
      },
      {
        title: "What Do I Do If I Damage My Dentures",
        description: "Steps to take for damaged dentures.",
        url: "/patient-education/what-do-i-do-if-i-damage-my-dentures"
      },
      {
        title: "I Think My Gums Are Receding",
        description: "Signs and treatment for gum recession.",
        url: "/patient-education/i-think-my-gums-are-receding"
      }
    ]
  },
  {
    title: "Special Topics",
    items: [
      {
        title: "Do I Have Sleep Apnea",
        description: "Recognize sleep apnea symptoms.",
        url: "/patient-education/do-i-have-sleep-apnea"
      },
      {
        title: "Improve Your Smile for Senior Pictures",
        description: "Quick smile enhancement options.",
        url: "/patient-education/improve-your-smile-for-senior-pictures"
      },
      {
        title: "Dental Anxiety",
        description: "Tips for managing dental fear.",
        url: "/patient-education/dental-anxiety"
      },
      {
        title: "Oral Cancer Screening",
        description: "Importance of regular screenings.",
        url: "/patient-education/oral-cancer-screening"
      }
    ]
  },
  {
    title: "Additional Resources",
    items: [
      {
        title: "Blog",
        description: "Latest articles and dental health tips.",
        url: "/blog"
      }
    ]
  }
];
---

<Layout 
  title="Patient Education | Smile Dental Clinic"
  description="Educational resources about dental health, procedures, and treatments to help you make informed decisions about your oral care."
>
  <Hero 
    title="Patient Education"
    subtitle="Learn about dental health and treatments"
    imageUrl="https://images.pexels.com/photos/3943937/pexels-photo-3943937.jpeg"
  />
  
  <div class="container mx-auto px-4">
    <Breadcrumbs items={breadcrumbItems} />
    
    <div class="py-12">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Dental Health Resources</h2>
        <p class="text-neutral-600">
          Browse our collection of educational resources to learn more about dental health and treatments.
        </p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {resources.map(category => (
          <div class="bg-white p-6 rounded-lg shadow-md">
            <h3 class="text-xl font-semibold mb-4">{category.title}</h3>
            <ul class="space-y-3">
              {category.items.map(resource => (
                <li>
                  <a 
                    href={resource.url}
                    class="block p-3 rounded-lg hover:bg-primary-50 transition-colors"
                  >
                    <div class="font-medium text-primary-600">{resource.title}</div>
                    <p class="text-sm text-neutral-600 mt-1">{resource.description}</p>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</Layout>