---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { clinicInfo } from '../../utils/clinicInfo';

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: 'Patient Info', href: '/patient-information' },
  { label: 'Dictionary', href: '/patient-education/dental-dictionary' },
];

const terms = [
  { term: "Abutment", def: "A connector that attaches a dental implant to a crown, bridge, or denture." },
  { term: "Bruxism", def: "The habit of grinding or clenching teeth, often during sleep." },
  { term: "Calculus (Tartar)", def: "Hardened plaque that forms on teeth and can only be removed by a dentist." },
  { term: "Caries", def: "The technical term for tooth decay or cavities." },
  { term: "Crown", def: "A tooth-shaped 'cap' placed over a damaged tooth to restore its shape, size, and strength." },
  { term: "Dental Implant", def: "A titanium post surgically placed in the jawbone to replace a missing tooth root." },
  { term: "Endodontist", def: "A specialist who treats the inside of the tooth (pulp), commonly performing root canals." },
  { term: "Gingivitis", def: "The earliest stage of gum disease, characterized by red, swollen gums that may bleed easily." },
  { term: "Halitosis", def: "Chronic bad breath." },
  { term: "Malocclusion", def: "Misalignment of the teeth or jaws ('bad bite')." },
  { term: "Periodontal Disease", def: "Advanced gum disease that can lead to bone and tooth loss." },
  { term: "Plaque", def: "A sticky film of bacteria that forms on teeth and causes cavities and gum disease." },
  { term: "Prophylaxis", def: "Professional cleaning of the teeth to prevent disease." },
  { term: "Root Canal", def: "A treatment to save a tooth that is badly decayed or infected by removing the nerve." },
  { term: "Sealant", def: "A thin plastic coating applied to the chewing surfaces of back teeth to prevent decay." },
  { term: "Veneer", def: "A thin shell of porcelain bonded to the front of a tooth to improve its appearance." },
  { term: "Xerostomia", def: "Dry mouth caused by a lack of saliva." }
];
---

<Layout
  title="Dental Dictionary | Common Dental Terms Explained | NextGen Dental"
  description="Confused by dental jargon? Use our dental dictionary to understand common terms like abutment, calculus, and periodontal disease."
>
  <!-- Simple Header -->
  <div class="bg-primary-900 text-white pt-32 pb-16 relative overflow-hidden">
    <div class="container mx-auto px-4 text-center relative z-10">
      <h1 class="text-4xl md:text-5xl font-bold font-heading mb-4">Dental Dictionary</h1>
      <p class="text-primary-200 text-lg max-w-2xl mx-auto">
        Understanding your oral health starts with understanding the terminology.
      </p>
    </div>
  </div>

  <div class="bg-gray-50 border-b border-gray-200">
    <div class="container mx-auto px-4 py-3">
      <nav class="flex text-sm text-gray-500" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
          <li><a href="/" class="hover:text-primary-600">Home</a></li>
          <li><span class="text-gray-400">/</span></li>
          <li class="text-gray-900 font-medium">Dental Dictionary</li>
        </ol>
      </nav>
    </div>
  </div>

  <div class="py-16 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="grid gap-6">
        {terms.map((item) => (
          <div class="bg-gray-50 p-6 rounded-lg border border-gray-100 hover:border-primary-200 transition-colors">
            <h3 class="text-xl font-bold text-primary-700 mb-2">{item.term}</h3>
            <p class="text-gray-700">{item.def}</p>
          </div>
        ))}
      </div>
      
      <div class="mt-12 text-center bg-primary-50 p-8 rounded-xl">
        <h2 class="text-2xl font-bold text-gray-800 mb-4">Still have questions?</h2>
        <p class="text-gray-600 mb-6">
          We are happy to explain any procedure or term in person.
        </p>
        <a href="/contact" class="inline-block bg-primary-600 text-white px-6 py-3 rounded-md hover:bg-primary-700 transition-colors">
          Contact Us
        </a>
      </div>
    </div>
  </div>
</Layout>
