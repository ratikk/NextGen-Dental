---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Admin Dashboard - NextGen Dental">
  <div id="auth-check" class="min-h-screen bg-gray-50">
    <div class="flex items-center justify-center h-screen">
      <div class="text-center">
        <svg class="animate-spin h-12 w-12 text-blue-600 mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <p class="text-gray-600">Verifying authentication...</p>
      </div>
    </div>
  </div>

  <div id="dashboard-content" class="hidden min-h-screen bg-gray-50">
    <!-- Header -->
    <header class="bg-white shadow">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 flex justify-between items-center">
        <div>
          <h1 class="text-3xl font-bold text-gray-900">Content Management</h1>
          <p class="mt-1 text-sm text-gray-500">Manage your website content</p>
        </div>
        <button
          id="logout-btn"
          class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-colors"
        >
          Sign Out
        </button>
      </div>
    </header>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <!-- Navigation Tabs -->
      <div class="mb-8">
        <nav class="flex space-x-4 border-b border-gray-200">
          <button data-tab="homepage" class="tab-btn px-4 py-3 text-sm font-medium border-b-2 border-blue-600 text-blue-600">
            Homepage
          </button>
          <button data-tab="settings" class="tab-btn px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
            Site Settings
          </button>
          <button data-tab="services" class="tab-btn px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
            Services
          </button>
          <button data-tab="blog" class="tab-btn px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
            Blog Posts
          </button>
          <button data-tab="team" class="tab-btn px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
            Team
          </button>
          <button data-tab="gallery" class="tab-btn px-4 py-3 text-sm font-medium border-b-2 border-transparent text-gray-500 hover:text-gray-700 hover:border-gray-300">
            Gallery
          </button>
        </nav>
      </div>

      <!-- Tab Content -->
      <div id="tab-content" class="bg-white rounded-lg shadow p-6">
        <!-- Content will be loaded dynamically -->
      </div>
    </main>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = createClient(supabaseUrl, supabaseAnonKey);

  let currentUser: any = null;

  // Check authentication
  async function checkAuth() {
    const { data: { user }, error } = await supabase.auth.getUser();

    if (error || !user) {
      window.location.href = '/admin/login';
      return false;
    }

    currentUser = user;
    document.getElementById('auth-check')?.classList.add('hidden');
    document.getElementById('dashboard-content')?.classList.remove('hidden');

    // Load default tab
    loadTab('homepage');

    return true;
  }

  // Logout
  document.getElementById('logout-btn')?.addEventListener('click', async () => {
    await supabase.auth.signOut();
    window.location.href = '/admin/login';
  });

  // Tab switching
  const tabButtons = document.querySelectorAll('.tab-btn');
  tabButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = btn.getAttribute('data-tab');
      if (tab) {
        // Update active tab styling
        tabButtons.forEach(b => {
          b.classList.remove('border-blue-600', 'text-blue-600');
          b.classList.add('border-transparent', 'text-gray-500');
        });
        btn.classList.remove('border-transparent', 'text-gray-500');
        btn.classList.add('border-blue-600', 'text-blue-600');

        // Load tab content
        loadTab(tab);
      }
    });
  });

  // Load tab content
  async function loadTab(tab: string) {
    const content = document.getElementById('tab-content');
    if (!content) return;

    content.innerHTML = '<div class="flex justify-center py-12"><svg class="animate-spin h-8 w-8 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg></div>';

    switch (tab) {
      case 'homepage':
        await loadHomepage();
        break;
      case 'settings':
        await loadSettings();
        break;
      case 'services':
        await loadServices();
        break;
      case 'blog':
        content.innerHTML = '<p class="text-gray-600">Blog management coming soon...</p>';
        break;
      case 'team':
        content.innerHTML = '<p class="text-gray-600">Team management coming soon...</p>';
        break;
      case 'gallery':
        content.innerHTML = '<p class="text-gray-600">Gallery management coming soon...</p>';
        break;
    }
  }

  async function loadHomepage() {
    const { data, error } = await supabase
      .from('cms_homepage')
      .select('*')
      .maybeSingle();

    const content = document.getElementById('tab-content');
    if (!content) return;

    if (error || !data) {
      content.innerHTML = '<p class="text-red-600">Error loading homepage content</p>';
      return;
    }

    content.innerHTML = `
      <form id="homepage-form" class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Hero Heading</label>
          <input type="text" name="hero_heading" value="${data.hero_heading}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Hero Subheading</label>
          <textarea name="hero_subheading" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">${data.hero_subheading}</textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Primary CTA Text</label>
            <input type="text" name="cta_primary_text" value="${data.cta_primary_text}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Secondary CTA Text</label>
            <input type="text" name="cta_secondary_text" value="${data.cta_secondary_text}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Welcome Heading</label>
          <input type="text" name="welcome_heading" value="${data.welcome_heading}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Welcome Text</label>
          <textarea name="welcome_text" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">${data.welcome_text}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Features Heading</label>
          <input type="text" name="features_heading" value="${data.features_heading}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
        </div>
        <input type="hidden" name="id" value="${data.id}" />
        <button type="submit" class="w-full bg-blue-600 text-white py-2 px-4 rounded-lg hover:bg-blue-700 transition-colors">
          Save Changes
        </button>
      </form>
    `;

    setupHomepageForm();
  }

  async function loadSettings() {
    const { data, error } = await supabase
      .from('cms_site_settings')
      .select('*')
      .maybeSingle();

    const content = document.getElementById('tab-content');
    if (!content) return;

    if (error || !data) {
      content.innerHTML = '<p class="text-red-600">Error loading site settings</p>';
      return;
    }

    content.innerHTML = `
      <form id="settings-form" class="space-y-6">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Site Name</label>
            <input type="text" name="site_name" value="${data.site_name}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Tagline</label>
            <input type="text" name="tagline" value="${data.tagline}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Phone</label>
            <input type="text" name="phone" value="${data.phone}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Email</label>
            <input type="email" name="email" value="${data.email}" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Address</label>
          <textarea name="address" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">${data.address}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Office Hours</label>
          <textarea name="office_hours" rows="4" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">${data.office_hours}</textarea>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">Emergency Message</label>
          <textarea name="emergency_message" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">${data.emergency_message || ''}</textarea>
        </div>
        <input type="hidden" name="id" value="${data.id}" />
        <button type="submit" class="w-full bg-blue-600 text-white py-2 px-4 rounded-lg hover:bg-blue-700 transition-colors">
          Save Changes
        </button>
      </form>
    `;

    setupSettingsForm();
  }

  async function loadServices() {
    const { data, error } = await supabase
      .from('cms_services')
      .select('*')
      .order('title');

    const content = document.getElementById('tab-content');
    if (!content) return;

    if (error) {
      content.innerHTML = '<p class="text-red-600">Error loading services</p>';
      return;
    }

    content.innerHTML = `
      <div class="space-y-4">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-lg font-medium text-gray-900">Services</h3>
          <button id="add-service-btn" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">
            Add Service
          </button>
        </div>
        ${data && data.length > 0 ? `
          <div class="space-y-2">
            ${data.map(service => `
              <div class="flex items-center justify-between p-4 border border-gray-200 rounded-lg hover:bg-gray-50">
                <div>
                  <h4 class="font-medium text-gray-900">${service.title}</h4>
                  <p class="text-sm text-gray-500">${service.description}</p>
                </div>
                <button class="text-blue-600 hover:text-blue-700 font-medium">Edit</button>
              </div>
            `).join('')}
          </div>
        ` : '<p class="text-gray-500">No services yet. Add your first service!</p>'}
      </div>
    `;
  }

  function setupHomepageForm() {
    const form = document.getElementById('homepage-form') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      const { error } = await supabase
        .from('cms_homepage')
        .update({
          hero_heading: data.hero_heading,
          hero_subheading: data.hero_subheading,
          cta_primary_text: data.cta_primary_text,
          cta_secondary_text: data.cta_secondary_text,
          welcome_heading: data.welcome_heading,
          welcome_text: data.welcome_text,
          features_heading: data.features_heading,
          updated_at: new Date().toISOString(),
          updated_by: currentUser?.id
        })
        .eq('id', data.id);

      if (error) {
        alert('Error saving changes: ' + error.message);
      } else {
        alert('Changes saved successfully!');
      }
    });
  }

  function setupSettingsForm() {
    const form = document.getElementById('settings-form') as HTMLFormElement;
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);

      const { error } = await supabase
        .from('cms_site_settings')
        .update({
          site_name: data.site_name,
          tagline: data.tagline,
          phone: data.phone,
          email: data.email,
          address: data.address,
          office_hours: data.office_hours,
          emergency_message: data.emergency_message,
          updated_at: new Date().toISOString(),
          updated_by: currentUser?.id
        })
        .eq('id', data.id);

      if (error) {
        alert('Error saving changes: ' + error.message);
      } else {
        alert('Changes saved successfully!');
      }
    });
  }

  // Initialize
  checkAuth();
</script>
