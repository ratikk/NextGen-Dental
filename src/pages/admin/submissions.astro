---
import Layout from '../../layouts/Layout.astro';

// Mock data for now - will be replaced with AWS implementation
const submissions = [
  {
    id: '1',
    form_type: 'contact',
    data: { name: 'John Doe', email: 'john@example.com' },
    created_at: new Date().toISOString(),
    processed: false
  }
];
---

<Layout title="Form Submissions | Admin Dashboard">
  <div class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-8">Form Submissions</h1>
    
    <!-- Filters -->
    <div class="bg-white p-4 rounded-lg shadow mb-6">
      <div class="flex gap-4">
        <select id="type-filter" class="px-4 py-2 border rounded-lg">
          <option value="">All Types</option>
          <option value="contact">Contact</option>
          <option value="appointment">Appointment</option>
        </select>
        
        <input 
          type="date" 
          id="date-filter"
          class="px-4 py-2 border rounded-lg"
        />
        
        <button 
          id="clear-filters"
          class="px-4 py-2 bg-neutral-100 rounded-lg hover:bg-neutral-200 transition-colors"
        >
          Clear Filters
        </button>
      </div>
    </div>
    
    <!-- Submissions Table -->
    <div class="bg-white rounded-lg shadow overflow-hidden">
      <table class="w-full">
        <thead class="bg-neutral-50">
          <tr>
            <th class="px-6 py-3 text-left text-sm font-semibold text-neutral-600">Date</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-neutral-600">Type</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-neutral-600">Data</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-neutral-600">Status</th>
            <th class="px-6 py-3 text-left text-sm font-semibold text-neutral-600">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-200">
          {submissions?.map(submission => (
            <tr class="hover:bg-neutral-50">
              <td class="px-6 py-4 text-sm text-neutral-600">
                {new Date(submission.created_at).toLocaleDateString()}
              </td>
              <td class="px-6 py-4 text-sm text-neutral-600">
                {submission.form_type}
              </td>
              <td class="px-6 py-4 text-sm text-neutral-600">
                <pre class="whitespace-pre-wrap">{JSON.stringify(submission.data, null, 2)}</pre>
              </td>
              <td class="px-6 py-4 text-sm">
                <span class={`px-2 py-1 rounded-full text-xs ${submission.processed ? 'bg-green-100 text-green-800' : 'bg-yellow-100 text-yellow-800'}`}>
                  {submission.processed ? 'Processed' : 'Pending'}
                </span>
              </td>
              <td class="px-6 py-4 text-sm">
                <button 
                  class="text-primary-600 hover:text-primary-700"
                  data-id={submission.id}
                  onclick="markAsProcessed(this.dataset.id)"
                >
                  Mark as Processed
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>

<script>
  // Filter functionality
  const typeFilter = document.getElementById('type-filter');
  const dateFilter = document.getElementById('date-filter');
  const clearFilters = document.getElementById('clear-filters');
  const rows = document.querySelectorAll('tbody tr');
  
  function filterSubmissions() {
    const selectedType = typeFilter.value;
    const selectedDate = dateFilter.value;
    
    rows.forEach(row => {
      const type = row.children[1].textContent.trim();
      const date = row.children[0].textContent.trim();
      
      const typeMatch = !selectedType || type === selectedType;
      const dateMatch = !selectedDate || date === selectedDate;
      
      row.style.display = typeMatch && dateMatch ? '' : 'none';
    });
  }
  
  typeFilter?.addEventListener('change', filterSubmissions);
  dateFilter?.addEventListener('change', filterSubmissions);
  clearFilters?.addEventListener('click', () => {
    typeFilter.value = '';
    dateFilter.value = '';
    rows.forEach(row => row.style.display = '');
  });
  
  // Mark as processed functionality
  async function markAsProcessed(id) {
    try {
      // This will be implemented with AWS later
      console.log('Marking submission as processed:', id);
      window.location.reload();
    } catch (error) {
      console.error('Error marking submission as processed:', error);
    }
  }
</script>