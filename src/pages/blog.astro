---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const breadcrumbItems = [
  { label: 'Blog', href: '/blog' }
];

const blogPosts = [
  {
    title: "The Importance of Regular Dental Checkups",
    excerpt: "Learn why regular dental visits are crucial for maintaining optimal oral health and preventing serious dental problems.",
    date: "March 15, 2024",
    author: "Dr. Sarah Johnson",
    category: "Dental Health",
    image: "https://images.pexels.com/photos/3845757/pexels-photo-3845757.jpeg",
    url: "/blog/importance-of-regular-dental-checkups"
  },
  {
    title: "Understanding Different Types of Dental Fillings",
    excerpt: "A comprehensive guide to different filling materials and how to choose the right one for your needs.",
    date: "March 10, 2024",
    author: "Dr. Michael Rodriguez",
    category: "Dental Procedures",
    image: "https://images.pexels.com/photos/3845761/pexels-photo-3845761.jpeg",
    url: "/blog/types-of-dental-fillings"
  },
  {
    title: "Tips for Teaching Kids Good Oral Hygiene",
    excerpt: "Practical advice for parents on helping children develop healthy dental care habits from an early age.",
    date: "March 5, 2024",
    author: "Dr. Emily Chen",
    category: "Pediatric Dentistry",
    image: "https://images.pexels.com/photos/4546132/pexels-photo-4546132.jpeg",
    url: "/blog/teaching-kids-oral-hygiene"
  }
];

const categories = [
  "All",
  "Dental Health",
  "Dental Procedures",
  "Pediatric Dentistry",
  "Cosmetic Dentistry",
  "Oral Hygiene",
  "Dental Technology"
];
---

<Layout 
  title="Dental Health Blog | Smile Dental Clinic"
  description="Stay informed about dental health with our educational blog posts covering various topics in dentistry."
>
  <Hero 
    title="Dental Health Blog"
    subtitle="Expert insights and tips for maintaining your oral health"
    imageUrl="https://images.pexels.com/photos/3845729/pexels-photo-3845729.jpeg"
  />
  
  <div class="container mx-auto px-4">
    <Breadcrumbs items={breadcrumbItems} />
    
    <div class="py-12">
      <!-- Categories -->
      <div class="mb-12">
        <div class="flex flex-wrap gap-3">
          {categories.map(category => (
            <button class="px-4 py-2 rounded-full border border-primary-600 text-primary-600 hover:bg-primary-600 hover:text-white transition-colors">
              {category}
            </button>
          ))}
        </div>
      </div>
      
      <!-- Blog Posts Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {blogPosts.map(post => (
          <article class="bg-white rounded-lg shadow-md overflow-hidden">
            <a href={post.url} class="block">
              <img 
                src={post.image} 
                alt={post.title}
                class="w-full h-48 object-cover"
              />
            </a>
            <div class="p-6">
              <div class="flex items-center gap-4 text-sm text-neutral-600 mb-3">
                <span>{post.date}</span>
                <span>•</span>
                <span>{post.category}</span>
              </div>
              <h2 class="text-xl font-semibold mb-3">
                <a href={post.url} class="hover:text-primary-600 transition-colors">
                  {post.title}
                </a>
              </h2>
              <p class="text-neutral-600 mb-4">
                {post.excerpt}
              </p>
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-primary-100 rounded-full flex items-center justify-center text-primary-700 font-semibold">
                  {post.author.split(' ')[0][0]}{post.author.split(' ')[1][0]}
                </div>
                <span class="text-sm text-neutral-600">{post.author}</span>
              </div>
            </div>
          </article>
        ))}
      </div>
      
      <!-- Pagination -->
      <div class="mt-12 flex justify-center">
        <nav class="flex gap-2">
          <a href="#" class="px-4 py-2 border border-neutral-300 rounded-lg hover:bg-neutral-50 transition-colors">Previous</a>
          <a href="#" class="px-4 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors">1</a>
          <a href="#" class="px-4 py-2 border border-neutral-300 rounded-lg hover:bg-neutral-50 transition-colors">2</a>
          <a href="#" class="px-4 py-2 border border-neutral-300 rounded-lg hover:bg-neutral-50 transition-colors">3</a>
          <a href="#" class="px-4 py-2 border border-neutral-300 rounded-lg hover:bg-neutral-50 transition-colors">Next</a>
        </nav>
      </div>
    </div>
  </div>
</Layout>