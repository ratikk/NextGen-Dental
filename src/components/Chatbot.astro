---
import { useState } from 'react';

const Chatbot = () => {
  const [open, setOpen] = useState(false);

  const toggleChatbot = () => setOpen(!open);

  return (
    <div class="fixed bottom-4 right-4">
      <button
        class="bg-purple-600 text-white p-3 rounded-full shadow-lg hover:bg-purple-700"
        onClick={toggleChatbot}
      >
        Chat
      </button>
      {open && (
        <div class="bg-white border border-gray-300 rounded-lg shadow-lg p-4 w-80">
          <iframe
            src="https://example.com/your-chatbot-url"
            width="100%"
            height="400"
            frameborder="0"
            allow="microphone;"
          ></iframe>
          <button
            class="text-red-500 text-sm mt-2"
            onClick={toggleChatbot}
          >
            Close
          </button>
        </div>
      )}
    </div>
  );
};

export default Chatbot;
