---
interface Props {
  isVisible?: boolean;
}

const { isVisible = true } = Astro.props;
---

<div id="video-container" class={`fixed bottom-4 right-4 z-50 w-80 shadow-xl rounded-lg overflow-hidden ${!isVisible && 'hidden'}`}>
  <div class="bg-white p-2 flex justify-between items-center">
    <h3 class="text-sm font-medium">Welcome to Lilac Dental</h3>
    <button id="close-video" class="text-neutral-500 hover:text-neutral-700">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
      </svg>
    </button>
  </div>
  <video 
    id="promo-video"
    class="w-full aspect-video bg-black"
    controls
    preload="none"
    poster="/images/video-thumbnail.jpg"
  >
    <source src="/videos/lilac-dental-promo.mp4" type="video/mp4">
    <p class="p-4 text-white text-center">Your browser does not support the video tag.</p>
  </video>
</div>

<script>
  const videoContainer = document.getElementById('video-container');
  const closeButton = document.getElementById('close-video');
  const video = document.getElementById('promo-video') as HTMLVideoElement;

  // Check if video file exists
  fetch('/videos/lilac-dental-promo.mp4')
    .then(response => {
      if (!response.ok) {
        console.error('Video file not found');
        videoContainer?.classList.add('hidden');
      }
    })
    .catch(error => {
      console.error('Error checking video:', error);
      videoContainer?.classList.add('hidden');
    });

  // Load video visibility state from localStorage
  const isVideoHidden = localStorage.getItem('hidePromoVideo') === 'true';
  if (isVideoHidden) {
    videoContainer?.classList.add('hidden');
  }

  closeButton?.addEventListener('click', () => {
    videoContainer?.classList.add('hidden');
    video?.pause();
    // Store the state
    localStorage.setItem('hidePromoVideo', 'true');
    localStorage.setItem('videoHiddenTimestamp', Date.now().toString());
  });

  // Reset video visibility after 24 hours
  const lastHidden = localStorage.getItem('videoHiddenTimestamp');
  if (lastHidden) {
    const hoursSinceHidden = (Date.now() - parseInt(lastHidden)) / (1000 * 60 * 60);
    if (hoursSinceHidden >= 24) {
      localStorage.removeItem('hidePromoVideo');
      localStorage.removeItem('videoHiddenTimestamp');
      videoContainer?.classList.remove('hidden');
    }
  }

  // Add error handling for video
  video?.addEventListener('error', (e) => {
    console.error('Video error:', e);
    videoContainer?.classList.add('hidden');
  });
</script>
