---
interface Props {
  items: {
    label: string;
    href: string;
  }[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="py-4">
  <ol class="flex items-center gap-2 text-sm">
    <li>
      <a href="/" class="text-neutral-600 hover:text-primary-600 transition-colors">Home</a>
    </li>
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
        {index === items.length - 1 ? (
          <span class="text-neutral-900 font-medium">{item.label}</span>
        ) : (
          <a href={item.href} class="text-neutral-600 hover:text-primary-600 transition-colors">{item.label}</a>
        )}
      </li>
    ))}
  </ol>
</nav>