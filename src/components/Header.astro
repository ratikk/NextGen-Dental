---
import Button from './Button.astro';
import MobileMenu from './MobileMenu.astro';
import { clinicInfo } from '../utils/clinicInfo';
import { services } from '../utils/services';

const rawPhone = clinicInfo.phone.replace(/\D/g, '');
---

<header class="w-full fixed top-0 left-0 z-50 bg-white shadow-sm">
  <div class="hidden md:block bg-gray-50 py-2">
    <div class="container mx-auto px-4">
      <div class="flex justify-between items-center">

        <a href="/" class="flex items-center gap-2" aria-label="Lilac Dental Homepage">
          <img src="/images/logo.png" alt={`${clinicInfo.name} Logo`} class="h-8" />
        </a>

        <div class="flex items-center gap-4">
          <a
            href={clinicInfo.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-gray-600 hover:text-primary-600 transition-colors duration-200"
            aria-label="Open Google Maps Location"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{clinicInfo.address.full}</span>
          </a>

          <div class="flex items-center gap-2">
            <div class="secure-call-wrapper" data-phone={rawPhone}>
              <!-- SEO FIX: Point to /contact so bots see a valid link. JS will intercept for humans. -->
              <Button href="/contact" text="Call Us" variant="outline" size="lg" />
            </div>
            <Button href={clinicInfo.booking.zocdoc} text="Book Online" variant="primary" size="lg" target="_blank" rel="noopener noreferrer" />
            <Button href={clinicInfo.booking.modento} text="Patient Portal" variant="outline" size="lg" target="_blank" rel="noopener noreferrer" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <nav class="py-3 md:py-4 bg-white">
    <div class="container mx-auto px-4">
      <div class="flex items-center justify-between">
        <a href="/" class="lg:hidden flex items-center gap-2" aria-label="Lilac Dental Homepage">
          <img src="/images/logo.png" alt={`${clinicInfo.name} Logo`} class="h-8" />
        </a>

        <div class="flex lg:hidden items-center gap-2">
          <a
            href={clinicInfo.mapLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center w-9 h-9 rounded-lg border-2 border-primary-600 text-primary-600 hover:bg-primary-50 transition-colors duration-200"
            aria-label="Open Google Maps Directions"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
          </a>
          <div class="secure-call-wrapper-mobile" data-phone={rawPhone}>
            <Button href="/contact" text="Call" variant="outline" size="sm" />
          </div>
          <button id="menu-toggle-right" class="text-gray-700 focus:outline-none ml-2" aria-label="Open Mobile Menu">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>

        <div class="hidden lg:flex items-center space-x-8">
          <a href="/" class="nav-link">Home</a>
          <a href="/about" class="nav-link">About</a>
          <div class="relative group">
            <a href="/services" class="nav-link flex items-center gap-1">Services <span class="ml-1">▼</span></a>
            <div class="absolute left-0 top-full w-[800px] bg-white shadow-lg rounded-lg p-6 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 border border-gray-100">
              <div class="grid grid-cols-3 gap-6">
                {Object.entries(services).map(([key, category]) => (
                  <div>
                    <h3 class="font-bold text-gray-800 mb-2">{category.title}</h3>
                    <ul class="space-y-3">
                      {category.items.map(service => (
                        <li>
                          <a href={service.href} class="group/service block" aria-label={`View service: ${service.name}`}>
                            <div class="flex items-center gap-2">
                              <span class="text-lg">{service.icon}</span>
                              <span class="font-medium text-gray-700 group-hover/service:text-primary-600 transition-colors duration-200">{service.name}</span>
                            </div>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </div>
          </div>
          <a href="/smile-gallery" class="nav-link">Smile Gallery</a>
          <a href="/patient-information" class="nav-link">Patient Information</a>
          <a href="/blog" class="nav-link">Blog</a>
          <a href="/financing" class="nav-link">Financing</a>
          <a href="/reviews" class="nav-link">Reviews</a>
          <a href="/contact" class="nav-link">Contact</a>
        </div>
      </div>
    </div>
  </nav>
  <MobileMenu services={services} />
</header>

<style>
  .nav-link { @apply font-medium text-gray-700 hover:text-primary-600 transition-colors duration-200; }
</style>

<script>
  const menuToggleRight = document.getElementById('menu-toggle-right');
  const mobileMenu = document.getElementById('mobile-menu');
  if (menuToggleRight && mobileMenu) {
    menuToggleRight.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }

  // Logic: Intercept the click on /contact and force a call instead
  const callWrappers = document.querySelectorAll('.secure-call-wrapper, .secure-call-wrapper-mobile');
  callWrappers.forEach(wrapper => {
    const btn = wrapper.querySelector('a');
    if (btn && wrapper instanceof HTMLElement) {
      btn.addEventListener('click', (e) => {
        e.preventDefault(); // STOP browser from going to /contact
        const phone = wrapper.dataset.phone;
        if (phone) window.location.href = `tel:${phone}`; // Dial number instead
      });
    }
  });
</script>
