---
---
<div id="mobile-menu" class="lg:hidden fixed inset-0 bg-white z-50 hidden flex-col pt-16 pb-6 px-4 animate-fadeIn">
  <button id="mobile-menu-close" class="absolute top-4 right-4">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
  
  <div class="flex flex-col gap-3 mb-6">
    <a href="https://maps.google.com" target="_blank" class="flex items-center gap-2 py-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      Find Us on Google Maps
    </a>
    
    <a href="tel:+1234567890" class="flex items-center gap-2 py-2">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
      </svg>
      Call Us: (123) 456-7890
    </a>
  </div>
  
  <nav class="flex-grow">
    <ul class="flex flex-col gap-4">
      <li><a href="/" class="text-neutral-800 text-lg font-medium py-2 block border-b border-neutral-100">Home</a></li>
      <li><a href="/about" class="text-neutral-800 text-lg font-medium py-2 block border-b border-neutral-100">About</a></li>
      <li>
        <div class="mobile-dropdown py-2 border-b border-neutral-100">
          <div class="flex justify-between items-center">
            <a href="/services" class="text-neutral-800 text-lg font-medium">Services</a>
            <button class="mobile-dropdown-toggle">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
          </div>
          <ul class="mobile-dropdown-content hidden pl-4 mt-2 space-y-2">
            <li><a href="/services" class="block py-1 text-neutral-700">View All Services</a></li>
            <li><a href="/services/dental-checkup" class="block py-1 text-neutral-700">Dental Checkup</a></li>
            <li><a href="/services/teeth-whitening" class="block py-1 text-neutral-700">Teeth Whitening</a></li>
            <li><a href="/services/dental-implants" class="block py-1 text-neutral-700">Dental Implants</a></li>
            <li><a href="/services/invisalign" class="block py-1 text-neutral-700">Invisalign</a></li>
          </ul>
        </div>
      </li>
      <li><a href="/patient-information" class="text-neutral-800 text-lg font-medium py-2 block border-b border-neutral-100">Patient Information</a></li>
      <li><a href="/patient-education" class="text-neutral-800 text-lg font-medium py-2 block border-b border-neutral-100">Patient Education</a></li>
      <li><a href="/financing" class="text-neutral-800 text-lg font-medium py-2 block border-b border-neutral-100">Financing</a></li>
      <li><a href="/reviews" class="text-neutral-800 text-lg font-medium py-2 block border-b border-neutral-100">Reviews</a></li>
      <li><a href="/contact" class="text-neutral-800 text-lg font-medium py-2 block border-b border-neutral-100">Contact</a></li>
    </ul>
  </nav>
  
  <div class="mt-6">
    <a href="/book-appointment" class="bg-primary-600 text-white py-3 px-6 rounded-lg w-full block text-center font-medium hover:bg-primary-700 transition-colors">Book Appointment</a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const mobileMenuClose = document.getElementById('mobile-menu-close');
    const mobileMenu = document.getElementById('mobile-menu');
    const dropdownToggles = document.querySelectorAll('.mobile-dropdown-toggle');
    
    mobileMenuClose?.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
      mobileMenu?.classList.remove('flex');
    });
    
    dropdownToggles.forEach(toggle => {
      toggle.addEventListener('click', (e) => {
        const dropdown = (e.currentTarget as HTMLElement).closest('.mobile-dropdown');
        const content = dropdown?.querySelector('.mobile-dropdown-content');
        content?.classList.toggle('hidden');
      });
    });
  });
</script>